#!/bin/bash
# shellcheck shell=bash
# shellcheck disable=SC2016
# Generated by hpc-compose for job hpc-compose-run
#SBATCH --job-name=hpc-compose-run
#SBATCH --nodes=1

set -euo pipefail

BACKEND="${HPC_COMPOSE_BACKEND_OVERRIDE:-slurm}"
JOB_STATUS="RUNNING"
JOB_EXIT_CODE=""
SUPERVISOR_PID=$$
RECEIVED_SIGNAL=""
JOB_ROOT="${SLURM_SUBMIT_DIR:-$PWD}/.hpc-compose/${SLURM_JOB_ID}"
RESUME_ENABLED=0
RESUME_HOST_PATH=''
RESUME_CONTAINER_PATH='/hpc-compose/resume'
RESUME_COMPOSE_NAME='hpc-compose-run'
ATTEMPT="${SLURM_RESTART_COUNT:-0}"
IS_RESUME=0
if [[ "$RESUME_ENABLED" == "1" ]]; then
  JOB_TMP="$JOB_ROOT/attempts/$ATTEMPT"
  RESUME_META_DIR="$RESUME_HOST_PATH/_hpc-compose"
  RESUME_META_FILE="$RESUME_META_DIR/latest.json"
  mkdir -p "$RESUME_HOST_PATH" "$RESUME_META_DIR"
  if (( ATTEMPT > 0 )) || [[ -f "$RESUME_META_FILE" ]]; then
    IS_RESUME=1
  fi
else
  JOB_TMP="$JOB_ROOT"
  RESUME_META_DIR=""
  RESUME_META_FILE=""
fi
ALLOCATION_DIR="$JOB_TMP/allocation"
PRIMARY_NODE_FILE="$ALLOCATION_DIR/primary_node"
NODELIST_FILE="$ALLOCATION_DIR/nodes.txt"
SERVICE_NODELIST_DIR="$ALLOCATION_DIR/service-nodelists"
SERVICE_NODELIST_CONTAINER_DIR="/hpc-compose/job/allocation/service-nodelists"
LOG_DIR="$JOB_TMP/logs"
STATE_FILE="$JOB_TMP/state.json"
SERVICE_EXIT_MARKER_DIR="$JOB_TMP/service-exits"
CACHE_ROOT='/Users/nicolas/.cache/hpc-compose'
export ENROOT_CACHE_PATH="$CACHE_ROOT/runtime/${SLURM_JOB_ID}/cache"
export ENROOT_DATA_PATH="$CACHE_ROOT/runtime/${SLURM_JOB_ID}/data"
export ENROOT_TEMP_PATH="$CACHE_ROOT/runtime/${SLURM_JOB_ID}/tmp"
mkdir -p "$LOG_DIR" "$ALLOCATION_DIR" "$SERVICE_NODELIST_DIR" "$SERVICE_EXIT_MARKER_DIR" "$ENROOT_CACHE_PATH" "$ENROOT_DATA_PATH" "$ENROOT_TEMP_PATH"

SERVICE_PIDS=()
SERVICE_NAMES=()
SERVICE_STEP_NAMES=()
SERVICE_LOG_PATHS=()
SERVICE_HEALTHY=()
SERVICE_COMPLETED_SUCCESSFULLY=()
SERVICE_READINESS_CONFIGURED=()
SERVICE_FAILURE_POLICY_MODE=()
SERVICE_MAX_RESTARTS=()
SERVICE_BACKOFF_SECONDS=()
SERVICE_WINDOW_SECONDS=()
SERVICE_MAX_RESTARTS_IN_WINDOW=()
SERVICE_RESTART_COUNT=()
SERVICE_RESTART_FAILURES_IN_WINDOW=()
SERVICE_RESTART_FAILURE_TIMESTAMPS=()
SERVICE_LAST_EXIT_CODE=()
SERVICE_STARTED_AT=()
SERVICE_FINISHED_AT=()
SERVICE_FIRST_FAILURE_AT=()
SERVICE_FIRST_FAILURE_EXIT_CODE=()
SERVICE_FIRST_FAILURE_NODE=()
SERVICE_FIRST_FAILURE_RANK=()
SERVICE_PLACEMENT_MODE=()
SERVICE_STEP_NODES=()
SERVICE_STEP_NTASKS=()
SERVICE_STEP_NTASKS_PER_NODE=()
SERVICE_STEP_NODELIST=()
SERVICE_HOST_EPILOGUE_SCRIPTS=()
SERVICE_HOST_EPILOGUE_RAN=()
SERVICE_EVENT_HOOK_MANIFESTS=()
ALLOCATION_NODES=()
SERVICE_LAUNCH_FNS=()
SERVICE_DEPENDENTS=()
CLEANING_UP=0
WAIT_HELPER_EXITED=0
WAIT_HELPER_EXIT_STATUS=""
declare -A SERVICE_INDEX_BY_NAME=()

append_unique_mount() {
  local candidate=$1
  local existing
  for existing in "${PYXIS_MOUNTS[@]:-}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done
  PYXIS_MOUNTS+=("$candidate")
}

build_pyxis_mounts() {
  local extra
  PYXIS_MOUNTS=()
  append_unique_mount "$JOB_TMP:/hpc-compose/job"
  if [[ "$RESUME_ENABLED" == "1" ]]; then
    append_unique_mount "$RESUME_HOST_PATH:$RESUME_CONTAINER_PATH"
  fi
  if [[ "${HPC_COMPOSE_SERVICE_SCRATCH_ENABLED:-0}" == "1" && -n "${SCRATCH_HOST_PATH:-}" && -n "${SCRATCH_CONTAINER_PATH:-}" ]]; then
    append_unique_mount "$SCRATCH_HOST_PATH:$SCRATCH_CONTAINER_PATH"
  fi
  if [[ -e /etc/slurm/task_prolog.hk ]]; then
    append_unique_mount "/etc/slurm/task_prolog.hk:/etc/slurm/task_prolog.hk"
    append_unique_mount "/etc/slurm/task_prolog.hk:/etc/slurm/task_prolog"
  elif [[ -e /etc/slurm/task_prolog ]]; then
    append_unique_mount "/etc/slurm/task_prolog:/etc/slurm/task_prolog"
    append_unique_mount "/etc/slurm/task_prolog:/etc/slurm/task_prolog.hk"
  fi
  [[ -d /scratch ]] && append_unique_mount "/scratch:/scratch"
  [[ -e /usr/lib64/slurm/libslurmfull.so ]] && append_unique_mount "/usr/lib64/slurm/libslurmfull.so"
  [[ -e /usr/lib64/libhwloc.so.15 ]] && append_unique_mount "/usr/lib64/libhwloc.so.15"
  for extra in "$@"; do
    append_unique_mount "$extra"
  done
  local joined=""
  local item
  for item in "${PYXIS_MOUNTS[@]}"; do
    if [[ -n "$joined" ]]; then
      joined+=","
    fi
    joined+="$item"
  done
  printf '%s' "$joined"
}

json_escape() {
  local value=$1
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

trim_whitespace() {
  local value=${1-}
  value=${value#"${value%%[![:space:]]*}"}
  value=${value%"${value##*[![:space:]]}"}
  printf '%s' "$value"
}

json_string_or_null() {
  local value=${1-}
  if [[ -z "$value" ]]; then
    printf 'null'
  else
    printf '"%s"' "$(json_escape "$value")"
  fi
}

json_number_or_null() {
  local value=${1-}
  if [[ -z "$value" ]]; then
    printf 'null'
  else
    printf '%s' "$value"
  fi
}

json_number_array() {
  local raw_values=${1-}
  local -a values=()
  local value
  printf '['
  if [[ -n "$raw_values" ]]; then
    read -r -a values <<< "$raw_values"
    local first=1
    for value in "${values[@]}"; do
      [[ -z "$value" ]] && continue
      if (( first == 0 )); then
        printf ','
      fi
      printf '%s' "$value"
      first=0
    done
  fi
  printf ']'
}

reset_wait_helper_exit_state() {
  WAIT_HELPER_EXITED=0
  WAIT_HELPER_EXIT_STATUS=""
}

record_wait_helper_exit() {
  local pid=$1
  local status=0
  wait "$pid" || status=$?
  WAIT_HELPER_EXITED=1
  WAIT_HELPER_EXIT_STATUS="$status"
}

replace_with_symlink() {
  local link_path=$1
  local target=$2
  if [[ -L "$link_path" || -f "$link_path" ]]; then
    rm -f "$link_path"
  elif [[ -d "$link_path" ]]; then
    rm -rf "$link_path"
  fi
  ln -s "$target" "$link_path"
}

update_latest_runtime_links() {
  [[ "$RESUME_ENABLED" == "1" ]] || return 0
  replace_with_symlink "$JOB_ROOT/allocation" "$ALLOCATION_DIR"
  replace_with_symlink "$JOB_ROOT/logs" "$LOG_DIR"
  replace_with_symlink "$JOB_ROOT/state.json" "$STATE_FILE"
}

resolve_allocation_metadata() {
  local -a allocation_nodes=()
  local primary_node="${SLURMD_NODENAME:-${HOSTNAME:-}}"
  if [[ -z "$primary_node" ]]; then
    primary_node=$(hostname)
  fi
  if [[ -z "$primary_node" ]]; then
    echo "failed to derive primary node metadata for single-node allocation" >&2
    exit 1
  fi
  allocation_nodes=("$primary_node")
  HPC_COMPOSE_PRIMARY_NODE="$primary_node"
  HPC_COMPOSE_NODE_COUNT=1
  HPC_COMPOSE_NODELIST="$primary_node"
  HPC_COMPOSE_NODELIST_FILE="/hpc-compose/job/allocation/nodes.txt"
  printf '%s\n' "${allocation_nodes[@]}" > "$NODELIST_FILE"
  printf '%s\n' "$HPC_COMPOSE_PRIMARY_NODE" > "$PRIMARY_NODE_FILE"
  ALLOCATION_NODES=("${allocation_nodes[@]}")
  export HPC_COMPOSE_PRIMARY_NODE HPC_COMPOSE_NODE_COUNT HPC_COMPOSE_NODELIST HPC_COMPOSE_NODELIST_FILE
}

nodes_for_indices() {
  local -a nodes=()
  local index
  for index in "$@"; do
    if [[ -z "$index" ]]; then
      continue
    fi
    if (( index < 0 || index >= ${#ALLOCATION_NODES[@]} )); then
      echo "service placement references allocation node index $index, but ${#ALLOCATION_NODES[@]} node(s) are available" >&2
      exit 1
    fi
    nodes+=("${ALLOCATION_NODES[index]}")
  done
  printf '%s' "${nodes[*]}"
}

comma_join_words() {
  local raw=${1:-}
  local -a words=()
  local joined=""
  local word
  read -r -a words <<< "$raw"
  for word in "${words[@]}"; do
    [[ -z "$word" ]] && continue
    if [[ -n "$joined" ]]; then
      joined+=","
    fi
    joined+="$word"
  done
  printf '%s' "$joined"
}

word_count() {
  local raw=${1:-}
  local -a words=()
  if [[ -z "$raw" ]]; then
    printf '0'
    return 0
  fi
  read -r -a words <<< "$raw"
  printf '%s' "${#words[@]}"
}

first_word() {
  local raw=${1:-}
  local -a words=()
  read -r -a words <<< "$raw"
  printf '%s' "${words[0]:-}"
}

write_nodelist_file() {
  local path=$1
  local nodelist=$2
  local -a nodes=()
  local node
  mkdir -p "$(dirname "$path")"
  : > "$path"
  read -r -a nodes <<< "$nodelist"
  for node in "${nodes[@]}"; do
    [[ -z "$node" ]] && continue
    printf '%s\n' "$node" >> "$path"
  done
}

write_resume_metadata() {
  [[ "$RESUME_ENABLED" == "1" ]] || return 0
  local tmp_resume="$RESUME_META_FILE.tmp"
  {
    printf '{\n'
    printf '  "schema_version": 1,\n'
    printf '  "compose_name": "%s",\n' "$(json_escape "$RESUME_COMPOSE_NAME")"
    printf '  "job_id": "%s",\n' "$(json_escape "$SLURM_JOB_ID")"
    printf '  "attempt": %s,\n' "$ATTEMPT"
    printf '  "updated_at": "%s"\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf '}\n'
  } > "$tmp_resume"
  mv "$tmp_resume" "$RESUME_META_FILE"
}

write_state_file() {
  local tmp_state="$STATE_FILE.tmp"
  {
    printf '{\n'
    printf '  "backend": "%s",\n' "$(json_escape "$BACKEND")"
    printf '  "job_status": "%s",\n' "$(json_escape "$JOB_STATUS")"
    printf '  "job_exit_code": %s,\n' "$(json_number_or_null "$JOB_EXIT_CODE")"
    printf '  "supervisor_pid": %s,\n' "$(json_number_or_null "$SUPERVISOR_PID")"
    if [[ "$RESUME_ENABLED" == "1" ]]; then
      printf '  "attempt": %s,\n' "$ATTEMPT"
      printf '  "is_resume": %s,\n' "$(if [[ "$IS_RESUME" == "1" ]]; then printf true; else printf false; fi)"
      printf '  "resume_dir": "%s",\n' "$(json_escape "$RESUME_HOST_PATH")"
    else
      printf '  "attempt": null,\n'
      printf '  "is_resume": null,\n'
      printf '  "resume_dir": null,\n'
    fi
    printf '  "services": ['
    local first=1
    local i
    for i in "${!SERVICE_NAMES[@]}"; do
      if (( first == 0 )); then
        printf ','
      fi
      printf '\n    {"service_name":"%s","step_name":"%s","log_path":"%s","launch_index":%s,"launcher_pid":%s,"healthy":%s,"completed_successfully":%s,"readiness_configured":%s,"failure_policy_mode":"%s","restart_count":%s,"max_restarts":%s,"window_seconds":%s,"max_restarts_in_window":%s,"restart_failures_in_window":%s,"restart_failure_timestamps":%s,"last_exit_code":%s,"started_at":%s,"finished_at":%s,"first_failure_at":%s,"first_failure_exit_code":%s,"first_failure_node":%s,"first_failure_rank":%s,"placement_mode":%s,"nodes":%s,"ntasks":%s,"ntasks_per_node":%s,"nodelist":%s' \
        "$(json_escape "${SERVICE_NAMES[i]}")" \
        "$(json_escape "${SERVICE_STEP_NAMES[i]:-}")" \
        "$(json_escape "${SERVICE_LOG_PATHS[i]:-}")" \
        "$i" \
        "${SERVICE_PIDS[i]:-0}" \
        "$(if [[ "${SERVICE_HEALTHY[i]:-0}" == "1" ]]; then printf true; else printf false; fi)" \
        "$(if [[ "${SERVICE_COMPLETED_SUCCESSFULLY[i]:-0}" == "1" ]]; then printf true; else printf false; fi)" \
        "$(if [[ -n "${SERVICE_READINESS_CONFIGURED[i]:-}" ]] && [[ "${SERVICE_READINESS_CONFIGURED[i]}" == "1" ]]; then printf true; else printf false; fi)" \
        "$(json_escape "${SERVICE_FAILURE_POLICY_MODE[i]:-fail_job}")" \
        "${SERVICE_RESTART_COUNT[i]:-0}" \
        "${SERVICE_MAX_RESTARTS[i]:-0}" \
        "${SERVICE_WINDOW_SECONDS[i]:-0}" \
        "${SERVICE_MAX_RESTARTS_IN_WINDOW[i]:-0}" \
        "${SERVICE_RESTART_FAILURES_IN_WINDOW[i]:-0}" \
        "$(json_number_array "${SERVICE_RESTART_FAILURE_TIMESTAMPS[i]:-}")" \
        "$(if [[ -n "${SERVICE_LAST_EXIT_CODE[i]:-}" ]]; then printf '%s' "${SERVICE_LAST_EXIT_CODE[i]}"; else printf null; fi)" \
        "$(json_number_or_null "${SERVICE_STARTED_AT[i]:-}")" \
        "$(json_number_or_null "${SERVICE_FINISHED_AT[i]:-}")" \
        "$(json_number_or_null "${SERVICE_FIRST_FAILURE_AT[i]:-}")" \
        "$(json_number_or_null "${SERVICE_FIRST_FAILURE_EXIT_CODE[i]:-}")" \
        "$(json_string_or_null "${SERVICE_FIRST_FAILURE_NODE[i]:-}")" \
        "$(json_string_or_null "${SERVICE_FIRST_FAILURE_RANK[i]:-}")" \
        "$(json_string_or_null "${SERVICE_PLACEMENT_MODE[i]:-}")" \
        "$(json_number_or_null "${SERVICE_STEP_NODES[i]:-}")" \
        "$(json_number_or_null "${SERVICE_STEP_NTASKS[i]:-}")" \
        "$(json_number_or_null "${SERVICE_STEP_NTASKS_PER_NODE[i]:-}")" \
        "$(json_string_or_null "${SERVICE_STEP_NODELIST[i]:-}")"
      printf '}'
      first=0
    done
    printf '\n  ]\n}\n'
  } > "$tmp_state"
  mv "$tmp_state" "$STATE_FILE"
}

resolve_allocation_metadata
update_latest_runtime_links
write_resume_metadata
write_state_file

kill_services() {
  for pid in "${SERVICE_PIDS[@]:-}"; do
    [[ -z "$pid" ]] && continue
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
  done
}

reap_services_after_cleanup() {
  local i
  for i in "${!SERVICE_PIDS[@]}"; do
    local pid=${SERVICE_PIDS[i]:-}
    [[ -z "$pid" ]] && continue
    local status=0
    wait "$pid" || status=$?
    handle_service_exit "$i" "$status" || true
  done
}

cleanup() {
  local code=$?
  trap - EXIT INT TERM
  CLEANING_UP=1
  if [[ -n "$RECEIVED_SIGNAL" ]]; then
    JOB_STATUS="CANCELLED"
  elif (( code == 0 )); then
    JOB_STATUS="COMPLETED"
  else
    JOB_STATUS="FAILED"
  fi
  JOB_EXIT_CODE="$code"
  local stage_out_status=0
  kill_services
  reap_services_after_cleanup
  write_state_file
  exit "$code"
}
trap cleanup EXIT
trap 'RECEIVED_SIGNAL=INT; exit 130' INT
trap 'RECEIVED_SIGNAL=TERM; exit 143' TERM

register_service() {
  local name=$1
  local pid=$2
  local step_name=$3
  local log_path=$4
  local failure_mode=$5
  local max_restarts=$6
  local backoff_seconds=$7
  local window_seconds=$8
  local max_restarts_in_window=$9
  local launch_fn=${10}
  local dependents_csv=${11}
  local placement_mode=${12}
  local step_nodes=${13}
  local step_ntasks=${14}
  local step_ntasks_per_node=${15}
  local step_nodelist=${16}
  local readiness_configured=${17}
  local host_epilogue_script=${18}
  local event_hooks_manifest=${19}
  local index=${SERVICE_INDEX_BY_NAME["$name"]:-}
  local launched_at
  launched_at=$(date +%s)
  if [[ -n "$index" ]]; then
    SERVICE_PIDS[index]="$pid"
    SERVICE_STEP_NAMES[index]="$step_name"
    SERVICE_LOG_PATHS[index]="$log_path"
    SERVICE_HEALTHY[index]="0"
    SERVICE_COMPLETED_SUCCESSFULLY[index]="0"
    SERVICE_READINESS_CONFIGURED[index]="$readiness_configured"
    SERVICE_PLACEMENT_MODE[index]="$placement_mode"
    SERVICE_STEP_NODES[index]="$step_nodes"
    SERVICE_STEP_NTASKS[index]="$step_ntasks"
    SERVICE_STEP_NTASKS_PER_NODE[index]="$step_ntasks_per_node"
    SERVICE_STEP_NODELIST[index]="$step_nodelist"
    if [[ -z "${SERVICE_STARTED_AT[index]:-}" ]]; then
      SERVICE_STARTED_AT[index]="$launched_at"
    fi
    SERVICE_FINISHED_AT[index]=""
    SERVICE_HOST_EPILOGUE_SCRIPTS[index]="$host_epilogue_script"
    SERVICE_HOST_EPILOGUE_RAN[index]="0"
    SERVICE_EVENT_HOOK_MANIFESTS[index]="$event_hooks_manifest"
    SERVICE_LAUNCH_FNS[index]="$launch_fn"
    if [[ -n "$dependents_csv" ]]; then
      SERVICE_DEPENDENTS[index]="$dependents_csv"
    fi
  else
    index=${#SERVICE_PIDS[@]}
    SERVICE_PIDS+=("$pid")
    SERVICE_NAMES+=("$name")
    SERVICE_STEP_NAMES+=("$step_name")
    SERVICE_LOG_PATHS+=("$log_path")
    SERVICE_HEALTHY+=("0")
    SERVICE_COMPLETED_SUCCESSFULLY+=("0")
    SERVICE_READINESS_CONFIGURED+=("$readiness_configured")
    SERVICE_FAILURE_POLICY_MODE+=("$failure_mode")
    SERVICE_MAX_RESTARTS+=("$max_restarts")
    SERVICE_BACKOFF_SECONDS+=("$backoff_seconds")
    SERVICE_WINDOW_SECONDS+=("$window_seconds")
    SERVICE_MAX_RESTARTS_IN_WINDOW+=("$max_restarts_in_window")
    SERVICE_RESTART_COUNT+=("0")
    SERVICE_RESTART_FAILURES_IN_WINDOW+=("0")
    SERVICE_RESTART_FAILURE_TIMESTAMPS+=("")
    SERVICE_LAST_EXIT_CODE+=("")
    SERVICE_STARTED_AT+=("$launched_at")
    SERVICE_FINISHED_AT+=("")
    SERVICE_FIRST_FAILURE_AT+=("")
    SERVICE_FIRST_FAILURE_EXIT_CODE+=("")
    SERVICE_FIRST_FAILURE_NODE+=("")
    SERVICE_FIRST_FAILURE_RANK+=("")
    SERVICE_PLACEMENT_MODE+=("$placement_mode")
    SERVICE_STEP_NODES+=("$step_nodes")
    SERVICE_STEP_NTASKS+=("$step_ntasks")
    SERVICE_STEP_NTASKS_PER_NODE+=("$step_ntasks_per_node")
    SERVICE_STEP_NODELIST+=("$step_nodelist")
    SERVICE_HOST_EPILOGUE_SCRIPTS+=("$host_epilogue_script")
    SERVICE_HOST_EPILOGUE_RAN+=("0")
    SERVICE_EVENT_HOOK_MANIFESTS+=("$event_hooks_manifest")
    SERVICE_LAUNCH_FNS+=("$launch_fn")
    SERVICE_DEPENDENTS+=("$dependents_csv")
    SERVICE_INDEX_BY_NAME["$name"]=$index
  fi
  write_state_file
}

prune_restart_window() {
  local index=$1
  local now=${2:-$(date +%s)}
  local window_seconds=${SERVICE_WINDOW_SECONDS[index]:-0}
  local raw_timestamps=${SERVICE_RESTART_FAILURE_TIMESTAMPS[index]:-}
  local -a kept=()
  local -a timestamps=()
  local ts
  if [[ -n "$raw_timestamps" ]]; then
    read -r -a timestamps <<< "$raw_timestamps"
    for ts in "${timestamps[@]}"; do
      [[ -z "$ts" ]] && continue
      if (( now - ts < window_seconds )); then
        kept+=("$ts")
      fi
    done
  fi
  SERVICE_RESTART_FAILURE_TIMESTAMPS[index]="${kept[*]:-}"
  SERVICE_RESTART_FAILURES_IN_WINDOW[index]="${#kept[@]}"
}

service_index_for() {
  local name=$1
  local index=${SERVICE_INDEX_BY_NAME["$name"]:-}
  if [[ -z "$index" ]]; then
    echo "Dependency '$name' was not launched" >&2
    return 1
  fi
  printf '%s' "$index"
}

wait_for_sleep() {
  local pid=$1
  local name=$2
  local seconds=$3
  local start
  start=$(date +%s)
  reset_wait_helper_exit_state
  while (( $(date +%s) - start < seconds )); do
    if ! kill -0 "$pid" 2>/dev/null; then
      record_wait_helper_exit "$pid"
      return 1
    fi
    sleep 1
  done
  if ! kill -0 "$pid" 2>/dev/null; then
    record_wait_helper_exit "$pid"
    return 1
  fi
}

wait_for_tcp() {
  local pid=$1
  local name=$2
  local host=$3
  local port=$4
  local timeout=${5:-60}
  local start
  start=$(date +%s)
  reset_wait_helper_exit_state
  until bash -lc "</dev/tcp/${host}/${port}" >/dev/null 2>&1; do
    if ! kill -0 "$pid" 2>/dev/null; then
      record_wait_helper_exit "$pid"
      return 1
    fi
    if (( $(date +%s) - start >= timeout )); then
      echo "Timed out waiting for ${host}:${port} for service '$name'" >&2
      return 1
    fi
    sleep 1
  done
}

wait_for_log() {
  local pid=$1
  local name=$2
  local logfile=$3
  local pattern=$4
  local timeout=${5:-60}
  local start
  start=$(date +%s)
  reset_wait_helper_exit_state
  until grep -E -q "$pattern" "$logfile" 2>/dev/null; do
    if ! kill -0 "$pid" 2>/dev/null; then
      record_wait_helper_exit "$pid"
      return 1
    fi
    if (( $(date +%s) - start >= timeout )); then
      echo "Timed out waiting for readiness log pattern for service '$name'" >&2
      return 1
    fi
    sleep 1
  done
}

wait_for_http() {
  local pid=$1
  local name=$2
  local url=$3
  local expected=$4
  local timeout=${5:-60}
  local start
  start=$(date +%s)
  reset_wait_helper_exit_state
  while true; do
    if ! kill -0 "$pid" 2>/dev/null; then
      record_wait_helper_exit "$pid"
      return 1
    fi
    local code
    code=$(curl --silent --output /dev/null --write-out '%{http_code}' "$url" 2>/dev/null || true)
    if [[ "$code" == "$expected" ]]; then
      return 0
    fi
    if (( $(date +%s) - start >= timeout )); then
      echo "Timed out waiting for HTTP $expected from $url for service '$name'" >&2
      return 1
    fi
    sleep 1
  done
}

wait_for_service_started() {
  local dependency=$1
  local target=$2
  local index
  while true; do
    index=$(service_index_for "$dependency") || return 1
    local pid=${SERVICE_PIDS[index]:-}
    if [[ -z "$pid" ]]; then
      echo "Dependency '$dependency' for service '$target' does not have a tracked pid" >&2
      return 1
    fi
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    local status=0
    wait "$pid" || status=$?
    handle_service_exit "$index" "$status"
    local handled_status=$?
    if (( handled_status == 0 )) && [[ -n "${SERVICE_PIDS[index]:-}" ]]; then
      continue
    fi
    if (( handled_status == 0 )); then
      echo "Dependency '$dependency' exited with status $status before service '$target' could start" >&2
    fi
    return 1
  done
}

wait_for_service_healthy() {
  local dependency=$1
  local target=$2
  local wait_fn=$3
  local index
  while true; do
    index=$(service_index_for "$dependency") || return 1
    wait_for_service_started "$dependency" "$target" || return 1
    index=$(service_index_for "$dependency") || return 1
    if [[ "${SERVICE_HEALTHY[index]:-0}" == "1" ]]; then
      return 0
    fi
    local pid=${SERVICE_PIDS[index]}
    if "$wait_fn" "$pid" "$dependency"; then
      SERVICE_HEALTHY[index]="1"
      write_state_file
      return 0
    fi
    if [[ "$WAIT_HELPER_EXITED" == "1" ]]; then
      local status=$WAIT_HELPER_EXIT_STATUS
      handle_service_exit "$index" "$status"
      local handled_status=$?
      if (( handled_status == 0 )) && [[ -n "${SERVICE_PIDS[index]:-}" ]]; then
        continue
      fi
      if (( handled_status == 0 )); then
        echo "Dependency '$dependency' exited with status $status before it became healthy for service '$target'" >&2
      fi
    fi
    return 1
  done
}

wait_for_service_completed_successfully() {
  local dependency=$1
  local target=$2
  local index
  while true; do
    index=$(service_index_for "$dependency") || return 1
    if [[ "${SERVICE_COMPLETED_SUCCESSFULLY[index]:-0}" == "1" ]]; then
      return 0
    fi
    local pid=${SERVICE_PIDS[index]:-}
    if [[ -z "$pid" ]]; then
      if [[ "${SERVICE_LAST_EXIT_CODE[index]:-}" == "0" ]]; then
        SERVICE_COMPLETED_SUCCESSFULLY[index]="1"
        write_state_file
        return 0
      fi
      echo "Dependency '$dependency' for service '$target' did not complete successfully" >&2
      return 1
    fi
    local status=0
    wait "$pid" || status=$?
    handle_service_exit "$index" "$status"
    local handled_status=$?
    if (( handled_status != 0 )); then
      echo "Dependency '$dependency' failed with status $handled_status before service '$target' could start" >&2
      return "$handled_status"
    fi
    if [[ "${SERVICE_COMPLETED_SUCCESSFULLY[index]:-0}" == "1" ]]; then
      return 0
    fi
  done
}

emit_dependency_failure_diagnostic() {
  local failed_service=$1
  local index
  index=$(service_index_for "$failed_service") || return 0
  local dependents_csv=${SERVICE_DEPENDENTS[index]:-}
  [[ -z "$dependents_csv" ]] && return 0
  local formatted=${dependents_csv//,/ , }
  echo "Service '$failed_service' is required by: $formatted" >&2
}

write_service_exit_marker() {
  local index=$1
  local status=$2
  local service_name=${SERVICE_NAMES[index]:-unknown}
  local marker_name
  marker_name=$(printf '%s' "$service_name" | tr -c 'A-Za-z0-9_.-' '_')
  local marker="$SERVICE_EXIT_MARKER_DIR/${marker_name}.jsonl"
  mkdir -p "$SERVICE_EXIT_MARKER_DIR"
  printf '{"service":"%s","exit_code":%s,"at_unix":%s,"node":%s,"rank":%s,"nodelist":%s}\n' \
    "$(json_escape "$service_name")" \
    "$status" \
    "$(date +%s)" \
    "$(json_string_or_null "${SERVICE_FIRST_FAILURE_NODE[index]:-}")" \
    "$(json_string_or_null "${SERVICE_FIRST_FAILURE_RANK[index]:-}")" \
    "$(json_string_or_null "${SERVICE_STEP_NODELIST[index]:-}")" >> "$marker"
}

handle_service_exit() {
  local index=$1
  local status=$2
  local name=${SERVICE_NAMES[index]:-}
  local mode=${SERVICE_FAILURE_POLICY_MODE[index]:-fail_job}
  local max_restarts=${SERVICE_MAX_RESTARTS[index]:-0}
  local restart_count=${SERVICE_RESTART_COUNT[index]:-0}
  local backoff_seconds=${SERVICE_BACKOFF_SECONDS[index]:-0}
  local window_seconds=${SERVICE_WINDOW_SECONDS[index]:-0}
  local max_restarts_in_window=${SERVICE_MAX_RESTARTS_IN_WINDOW[index]:-0}
  local launch_fn=${SERVICE_LAUNCH_FNS[index]:-}
  local logfile=${SERVICE_LOG_PATHS[index]:-}
  local host_epilogue_script=${SERVICE_HOST_EPILOGUE_SCRIPTS[index]:-}
  SERVICE_PIDS[index]=''
  local effective_status=$status
  if [[ -n "$host_epilogue_script" && "${SERVICE_HOST_EPILOGUE_RAN[index]:-0}" != "1" ]]; then
    SERVICE_HOST_EPILOGUE_RAN[index]="1"
    local epilogue_status=0
    run_host_hook "$host_epilogue_script" "$name" epilogue "$logfile" "$status" || epilogue_status=$?
    if (( epilogue_status != 0 )); then
      echo "Service '$name' epilogue exited with status $epilogue_status" >&2
      if (( status == 0 )); then
        effective_status=$epilogue_status
      fi
    fi
  fi
  status=$effective_status
  SERVICE_FINISHED_AT[index]="$(date +%s)"
  SERVICE_LAST_EXIT_CODE[index]="$status"
  if (( status != 0 )) && [[ -z "${SERVICE_FIRST_FAILURE_EXIT_CODE[index]:-}" ]]; then
    SERVICE_FIRST_FAILURE_AT[index]="$(date +%s)"
    SERVICE_FIRST_FAILURE_EXIT_CODE[index]="$status"
    SERVICE_FIRST_FAILURE_NODE[index]="$(first_word "${SERVICE_STEP_NODELIST[index]:-}")"
    SERVICE_FIRST_FAILURE_RANK[index]=""
  fi
  write_service_exit_marker "$index" "$status" || true
  if [[ "$mode" == "restart_on_failure" ]]; then
    prune_restart_window "$index"
  fi
  write_state_file
  if [[ "$CLEANING_UP" == "1" ]]; then
    return 0
  fi
  if (( status == 0 )); then
    SERVICE_COMPLETED_SUCCESSFULLY[index]="1"
    write_state_file
    return 0
  fi
  if [[ "$mode" == "ignore" ]]; then
    echo "Service '$name' exited with status $status; continuing because failure_policy is ignore" >&2
    return 0
  fi
  if [[ "$mode" == "restart_on_failure" ]]; then
    local restart_failures_in_window=${SERVICE_RESTART_FAILURES_IN_WINDOW[index]:-0}
    if (( restart_count >= max_restarts )); then
      echo "Service '$name' exited with status $status after $restart_count/$max_restarts restarts" >&2
      emit_dependency_failure_diagnostic "$name"
      return "$status"
    fi
    if (( restart_failures_in_window >= max_restarts_in_window )); then
      echo "Service '$name' exited with status $status after $restart_failures_in_window/$max_restarts_in_window restart-triggering exits in ${window_seconds}s" >&2
      emit_dependency_failure_diagnostic "$name"
      return "$status"
    fi
    local now
    now=$(date +%s)
    SERVICE_RESTART_FAILURE_TIMESTAMPS[index]="${SERVICE_RESTART_FAILURE_TIMESTAMPS[index]:-} $now"
    SERVICE_RESTART_FAILURE_TIMESTAMPS[index]="${SERVICE_RESTART_FAILURE_TIMESTAMPS[index]# }"
    prune_restart_window "$index" "$now"
    local next_restart=$((restart_count + 1))
    SERVICE_RESTART_COUNT[index]="$next_restart"
    write_state_file
    if [[ -z "$launch_fn" ]]; then
      echo "Service '$name' requested restart but no launch function is registered" >&2
      emit_dependency_failure_diagnostic "$name"
      return "$status"
    fi
    if (( backoff_seconds > 0 )); then
      sleep "$backoff_seconds"
    fi
    echo "Service '$name' exited with status $status; restarting ($next_restart/$max_restarts)" >&2
    "$launch_fn"
    return 0
  fi
  echo "Service '$name' exited with status $status" >&2
  emit_dependency_failure_diagnostic "$name"
  return "$status"
}

restart_service_for_dev() {
  local name=$1
  local index=${SERVICE_INDEX_BY_NAME["$name"]:-}
  if [[ -z "$index" ]]; then
    echo "dev reload requested unknown service '$name'" >&2
    return 0
  fi
  local pid=${SERVICE_PIDS[index]:-}
  if [[ -n "$pid" ]]; then
    if kill -0 "$pid" 2>/dev/null; then
      echo "Dev reload: stopping service '$name'" >&2
      kill "$pid" 2>/dev/null || true
    fi
    wait "$pid" 2>/dev/null || true
  fi
  SERVICE_PIDS[index]=''
  SERVICE_HEALTHY[index]='0'
  SERVICE_COMPLETED_SUCCESSFULLY[index]='0'
  SERVICE_LAST_EXIT_CODE[index]=''
  SERVICE_FINISHED_AT[index]=''
  write_state_file
  local launch_fn=${SERVICE_LAUNCH_FNS[index]:-}
  if [[ -z "$launch_fn" ]]; then
    echo "dev reload requested service '$name' but no launch function is registered" >&2
    return 0
  fi
  echo "Dev reload: restarting service '$name'" >&2
  "$launch_fn"
}

process_dev_restart_requests() {
  [[ -n "${HPC_COMPOSE_DEV_CONTROL_DIR:-}" ]] || return 0
  local request_dir="$HPC_COMPOSE_DEV_CONTROL_DIR/restart"
  [[ -d "$request_dir" ]] || return 0
  local shopt_state
  shopt_state=$(shopt -p nullglob)
  shopt -s nullglob
  local -a request_files=("$request_dir"/*.request)
  eval "$shopt_state"
  local request_file
  for request_file in "${request_files[@]}"; do
    [[ -f "$request_file" ]] || continue
    local service_name
    while IFS= read -r service_name; do
      [[ -z "$service_name" ]] && continue
      restart_service_for_dev "$service_name"
    done < "$request_file"
    rm -f "$request_file" || true
  done
}

monitor_services() {
  while true; do
    process_dev_restart_requests
    local tracked=0
    for i in "${!SERVICE_PIDS[@]}"; do
      local pid=${SERVICE_PIDS[i]}
      [[ -z "$pid" ]] && continue
      tracked=$((tracked + 1))
      if kill -0 "$pid" 2>/dev/null; then
        continue
      fi
      if wait "$pid"; then
        handle_service_exit "$i" 0
        local handled_status=$?
        if (( handled_status != 0 )); then
          return "$handled_status"
        fi
      else
        local status=$?
        handle_service_exit "$i" "$status"
        local handled_status=$?
        if (( handled_status != 0 )); then
          return "$handled_status"
        fi
      fi
    done
    if (( tracked == 0 )); then
      return 0
    fi
    sleep 1
  done
}

wait_until_run_ready() {
  local pid=$1
  local name=$2
  :
}

launch_run() {
  local service_name='run'
  local logfile="$LOG_DIR/run.log"
  if [[ -z "${SERVICE_INDEX_BY_NAME["$service_name"]:-}" ]]; then
    : > "$logfile"
  fi
  local host_prologue_script=""
  local host_epilogue_script=""
  local event_hooks_manifest=""
  local -a service_mounts=()
  local -a srun_cmd=('srun' '--nodes=1' '--exact' '--overlap' '--job-name=hpc-compose:run' '--ntasks=1' '--container-env=HPC_COMPOSE_ATTEMPT,HPC_COMPOSE_HOOK_PHASE,HPC_COMPOSE_IS_RESUME,HPC_COMPOSE_NODELIST,HPC_COMPOSE_NODELIST_FILE,HPC_COMPOSE_NODE_COUNT,HPC_COMPOSE_PRIMARY_NODE,HPC_COMPOSE_RESUME_DIR,HPC_COMPOSE_SERVICE_EXIT_CODE,HPC_COMPOSE_SERVICE_LOG,HPC_COMPOSE_SERVICE_NAME,HPC_COMPOSE_SERVICE_NODELIST,HPC_COMPOSE_SERVICE_NODELIST_FILE,HPC_COMPOSE_SERVICE_NODE_COUNT,HPC_COMPOSE_SERVICE_PRIMARY_NODE')
  local -a service_cmd=('echo' 'hi')
  local scratch_enabled=0
  local runtime_mounts
  local HPC_COMPOSE_SERVICE_SCRATCH_ENABLED="$scratch_enabled"
  runtime_mounts=$(build_pyxis_mounts "${service_mounts[@]}")
  srun_cmd+=(--container-image='/Users/nicolas/.cache/hpc-compose/base/bcbf6575d2c5dba2-busybox.sqsh')
  if [[ -n "$runtime_mounts" ]]; then
    srun_cmd+=("--container-mounts=$runtime_mounts")
  fi
  local service_nodelist="$HPC_COMPOSE_NODELIST"
  local service_srun_nodelist=""
  local service_primary_node
  service_primary_node=$(first_word "$service_nodelist")
  local service_node_count
  service_node_count=$(word_count "$service_nodelist")
  local service_nodelist_file="$SERVICE_NODELIST_DIR/run.nodes.txt"
  local service_nodelist_container="$SERVICE_NODELIST_CONTAINER_DIR/run.nodes.txt"
  write_nodelist_file "$service_nodelist_file" "$service_nodelist"
  echo "Starting service $service_name"
  local -a launch_env=()
  launch_env+=("HPC_COMPOSE_PRIMARY_NODE=$HPC_COMPOSE_PRIMARY_NODE")
  launch_env+=("HPC_COMPOSE_NODE_COUNT=$HPC_COMPOSE_NODE_COUNT")
  launch_env+=("HPC_COMPOSE_NODELIST=$HPC_COMPOSE_NODELIST")
  launch_env+=("HPC_COMPOSE_NODELIST_FILE=$HPC_COMPOSE_NODELIST_FILE")
  launch_env+=("HPC_COMPOSE_SERVICE_NAME=$service_name")
  launch_env+=("HPC_COMPOSE_SERVICE_LOG=/hpc-compose/job/logs/run.log")
  launch_env+=("HPC_COMPOSE_SERVICE_PRIMARY_NODE=$service_primary_node")
  launch_env+=("HPC_COMPOSE_SERVICE_NODE_COUNT=$service_node_count")
  launch_env+=("HPC_COMPOSE_SERVICE_NODELIST=$service_nodelist")
  launch_env+=("HPC_COMPOSE_SERVICE_NODELIST_FILE=$service_nodelist_container")
  if [[ "$scratch_enabled" == "1" ]]; then
    launch_env+=("HPC_COMPOSE_SCRATCH_DIR=$SCRATCH_CONTAINER_PATH")
    launch_env+=("HPC_COMPOSE_SCRATCH_HOST_PATH=$SCRATCH_HOST_PATH")
  fi
  if [[ "$RESUME_ENABLED" == "1" ]]; then
    launch_env+=("HPC_COMPOSE_RESUME_DIR=$RESUME_CONTAINER_PATH")
    launch_env+=("HPC_COMPOSE_ATTEMPT=$ATTEMPT")
    launch_env+=("HPC_COMPOSE_IS_RESUME=$IS_RESUME")
  fi
  local pid
  local prologue_status=0
  if [[ -n "$host_prologue_script" ]]; then
    run_host_hook "$host_prologue_script" "$service_name" prologue "$logfile" "" || prologue_status=$?
  fi
  if (( prologue_status != 0 )); then
    echo "Service '$service_name' prologue exited with status $prologue_status" >&2
    host_epilogue_script=""
    ( exit "$prologue_status" ) &
    pid=$!
  else
    local -a runtime_cmd=("${service_cmd[@]}")
    (
      set -euo pipefail
      if (( ${#launch_env[@]} == 0 )); then
        "${srun_cmd[@]}" "${runtime_cmd[@]}" >>"$logfile" 2>&1
      else
        env "${launch_env[@]}" "${srun_cmd[@]}" "${runtime_cmd[@]}" >>"$logfile" 2>&1
      fi
    ) &
    pid=$!
  fi
  register_service 'run' "$pid" 'hpc-compose:run' "$logfile" 'fail_job' 0 0 0 0 'launch_run' '' 'primary_node' 1 '1' '' "$service_nodelist" 0 "$host_epilogue_script" "$event_hooks_manifest"
}

launch_run

monitor_services
