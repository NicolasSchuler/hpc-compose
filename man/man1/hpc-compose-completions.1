.TH "HPC\-COMPOSE\-COMPLETIONS" "1" "" "hpc\-compose 0.1.22" "User Commands"
.SH NAME
hpc\-compose\-completions \- Generate shell completions
.SH SYNOPSIS
.nf
hpc\-compose completions [OPTIONS] <SHELL>
.fi
.SH DESCRIPTION
.PP
Generate shell completion scripts for the supported shells.
.SH OPTIONS
.TP
\fISHELL\fR
Shell to generate completions for. Possible values: bash, elvish, fish, powershell, zsh.
.TP
\fB--profile\fR \fINAME\fR
Profile name to load from .hpc\-compose/settings.toml.
.TP
\fB--settings\-file\fR \fIPATH\fR
Explicit settings file path; defaults to upward search for .hpc\-compose/settings.toml.
.TP
\fB-h\fR, \fB--help\fR
Print help (see a summary with '\-h').
.SH EXAMPLES
.nf
hpc\-compose completions bash
hpc\-compose completions zsh > ~/.zfunc/_hpc\-compose
hpc\-compose completions fish > ~/.config/fish/completions/hpc\-compose.fish
.fi
