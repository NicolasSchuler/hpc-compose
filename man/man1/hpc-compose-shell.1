.TH "HPC\-COMPOSE\-SHELL" "1" "" "hpc\-compose 0.1.47" "User Commands"
.SH NAME
hpc\-compose\-shell \- Open an interactive shell in a Slurm container
.SH SYNOPSIS
.nf
hpc\-compose shell [OPTIONS] \-\-image <IMAGE>
.fi
.SH DESCRIPTION
.PP
Launch a thin direct srun \-\-pty wrapper around a Pyxis container image. Defaults to bash \-l inside the container.
.SH OPTIONS
.TP
\fB--image\fR \fIIMAGE\fR
Container image to run interactively.
.TP
\fB--resources\fR \fINAME\fR
Settings resource profile to apply.
.TP
\fB--time\fR \fITIME\fR
Slurm time limit.
.TP
\fB--mem\fR \fIMEM\fR
Slurm memory request.
.TP
\fB--cpus\-per\-task\fR \fIN\fR
Slurm CPUs per task.
.TP
\fB--gpus\fR \fIN\fR
Slurm GPU count.
.TP
\fB--partition\fR \fIPARTITION\fR
Slurm partition.
.TP
\fB--env\fR \fIKEY=VALUE\fR
Environment variable to pass into the interactive container.
.TP
\fB--srun\-bin\fR \fIPATH\fR
Path to the srun executable. Default: srun.
.TP
\fB--color\fR \fIWHEN\fR
Controls colored output. Default: auto. Possible values: auto, always, never.
.TP
\fB--quiet\fR
Suppress progress indicators and non\-essential labels.
.TP
\fB--profile\fR \fINAME\fR
Profile name to load from .hpc\-compose/settings.toml.
.TP
\fB--settings\-file\fR \fIPATH\fR
Explicit settings file path; defaults to upward search for .hpc\-compose/settings.toml.
.TP
\fB-h\fR, \fB--help\fR
Print help (see a summary with '\-h').
.SH EXAMPLES
.nf
hpc\-compose shell \-\-image docker://ubuntu:24.04
hpc\-compose shell \-\-image docker://nvidia/cuda:12.4.1\-base\-ubuntu22.04 \-\-gpus 1
hpc\-compose shell \-\-image docker://python:3.12 \-\-resources cpu\-small
.fi
