{
  "schema_version": 1,
  "policy_version": "1.0.0",
  "cli_version": "0.2.3",
  "title": "hpc-compose agent command policy",
  "description": "Flag-aware effects and authorization requirements for every public hpc-compose command path.",
  "effect_tags": {
    "local-read": "Reads local files or process metadata without changing them.",
    "local-write": "Creates or changes local files, tracked records, caches, or generated artifacts.",
    "local-delete": "Deletes local files, cache entries, tracked state, or workspace data.",
    "executes-user-code": "Runs workload commands, preparation commands, probes, or an interactive runtime.",
    "network-or-ssh": "Uses the network, pulls remote content, opens a tunnel, or delegates over SSH.",
    "scheduler-read": "Queries Slurm or another external scheduler without changing scheduler state.",
    "scheduler-submit": "Submits a job or opens an allocation and may consume quota.",
    "scheduler-cancel": "Cancels, signals, requeues, or otherwise destructively changes a scheduled job.",
    "polls": "Repeats local, network, or scheduler observations until completion or interruption.",
    "sensitive-output": "May expose secrets, commands, scripts, paths, logs, tokens, or other sensitive material."
  },
  "authorization_tiers": [
    {
      "id": "automatic-read-only",
      "order": 1,
      "description": "May run automatically when its independent sensitive-output guard is also satisfied."
    },
    {
      "id": "scoped-local-mutation",
      "order": 2,
      "description": "Requires authorization for the named local write scope."
    },
    {
      "id": "explicit-runtime-or-external-mutation",
      "order": 3,
      "description": "Requires explicit authorization before executing workload code or changing an external non-scheduler resource."
    },
    {
      "id": "explicit-quota",
      "order": 4,
      "description": "Requires explicit authorization for scheduler submission, allocation, or quota consumption."
    },
    {
      "id": "explicit-destructive",
      "order": 5,
      "description": "Requires explicit authorization for deletion, cancellation, requeue, or other destructive mutation."
    }
  ],
  "global_overrides": [
    {
      "flag": "--offline",
      "remove_effects": [
        "network-or-ssh",
        "scheduler-read",
        "scheduler-submit",
        "scheduler-cancel",
        "polls"
      ],
      "description": "The CLI rejects SSH, network-backed delegation, scheduler contact, submissions, allocations, and cancels before invoking external tools. Local mutation and sensitive-output guards still apply."
    },
    {
      "flag": "--verbose",
      "add_effects": [
        "sensitive-output"
      ],
      "description": "Verbose diagnostics may reveal resolved paths, runtime details, or command material."
    },
    {
      "flag": "--debug",
      "add_effects": [
        "sensitive-output"
      ],
      "description": "Debug diagnostics may reveal resolved paths, runtime details, or command material."
    }
  ],
  "commands": [
    {
      "path": "alloc",
      "authorization_tier": "explicit-quota",
      "effects": [
        "local-read",
        "local-write",
        "executes-user-code",
        "network-or-ssh",
        "scheduler-read",
        "scheduler-submit",
        "polls",
        "sensitive-output"
      ],
      "summary": "Prepare images, open a Slurm allocation, and run a shell or command."
    },
    {
      "path": "artifacts",
      "authorization_tier": "scoped-local-mutation",
      "effects": [
        "local-read",
        "local-write"
      ],
      "summary": "Export tracked artifact bundles into the configured local destination."
    },
    {
      "path": "cache",
      "authorization_tier": "automatic-read-only",
      "effects": [],
      "summary": "Command group; a subcommand is required."
    },
    {
      "path": "cache inspect",
      "authorization_tier": "automatic-read-only",
      "effects": [
        "local-read"
      ],
      "summary": "Inspect one cache entry."
    },
    {
      "path": "cache list",
      "authorization_tier": "automatic-read-only",
      "effects": [
        "local-read"
      ],
      "summary": "List cache entries."
    },
    {
      "path": "cache prune",
      "authorization_tier": "explicit-destructive",
      "effects": [
        "local-read",
        "local-write",
        "local-delete"
      ],
      "summary": "Delete old or unused cache entries."
    },
    {
      "path": "cancel",
      "authorization_tier": "explicit-destructive",
      "effects": [
        "local-read",
        "local-write",
        "local-delete",
        "scheduler-cancel"
      ],
      "summary": "Cancel a tracked job and reap tracked state."
    },
    {
      "path": "checkpoints",
      "authorization_tier": "automatic-read-only",
      "effects": [
        "local-read"
      ],
      "summary": "Read local checkpoint and requeue history."
    },
    {
      "path": "clean",
      "authorization_tier": "explicit-destructive",
      "effects": [
        "local-read",
        "local-write",
        "local-delete"
      ],
      "summary": "Delete tracked job and optional deep runtime state.",
      "overrides": [
        {
          "flags": [
            "--dry-run"
          ],
          "authorization_tier": "automatic-read-only",
          "remove_effects": [
            "local-write",
            "local-delete"
          ],
          "description": "Preview the cleanup plan without deleting files."
        }
      ]
    },
    {
      "path": "completions",
      "authorization_tier": "automatic-read-only",
      "effects": [
        "local-read"
      ],
      "summary": "Print a shell completion program to stdout."
    },
    {
      "path": "config",
      "authorization_tier": "automatic-read-only",
      "effects": [
        "local-read"
      ],
      "summary": "Print the normalized effective compose configuration with redaction by default.",
      "overrides": [
        {
          "flags": [
            "--show-values"
          ],
          "add_effects": [
            "sensitive-output"
          ],
          "description": "Disables redaction of sensitive-looking values. Agents must not use or ingest this output."
        }
      ]
    },
    {
      "path": "context",
      "authorization_tier": "automatic-read-only",
      "effects": [
        "local-read"
      ],
      "summary": "Print selected settings, interpolation sources, binaries, and runtime paths with redaction by default.",
      "overrides": [
        {
          "flags": [
            "--show-values"
          ],
          "add_effects": [
            "sensitive-output"
          ],
          "description": "Disables redaction of sensitive-looking interpolation values. Agents must not use or ingest this output."
        }
      ]
    },
    {
      "path": "debug",
      "authorization_tier": "automatic-read-only",
      "effects": [
