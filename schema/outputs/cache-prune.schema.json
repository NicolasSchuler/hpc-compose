{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CachePruneReport",
  "type": "object",
  "properties": {
    "cache_dir": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "removed_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0
    },
    "removed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "schema_version",
    "cache_dir",
    "mode",
    "removed_count",
    "removed_paths"
  ]
}
