{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StatusOutput",
  "description": "`status` combined tracked-job status (`--format json`).",
  "type": "object",
  "properties": {
    "array": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArrayStatusSnapshot"
        },
        {
          "type": "null"
        }
      ]
    },
    "attempt": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0
    },
    "batch_log": {
      "$ref": "#/$defs/BatchLogStatus"
    },
    "is_resume": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "log_dir": {
      "type": "string"
    },
    "queue_diagnostics": {
      "anyOf": [
        {
          "$ref": "#/$defs/QueueDiagnostics"
        },
        {
          "type": "null"
        }
      ]
    },
    "record": {
      "$ref": "#/$defs/SubmissionRecord"
    },
    "resume_dir": {
      "type": [
        "string",
        "null"
      ]
    },
    "scheduler": {
      "$ref": "#/$defs/SchedulerStatus"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "services": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PsServiceRow"
      }
    },
    "telemetry_coverage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CollectorCoverageSummary"
      }
    },
    "verification": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusVerificationReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "watchdog": {
      "anyOf": [
        {
          "$ref": "#/$defs/WatchdogSnapshot"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "schema_version",
    "record",
    "scheduler",
    "log_dir",
    "batch_log",
    "services"
  ],
  "$defs": {
    "ArrayStatusSnapshot": {
      "description": "Slurm array task rows observed by `status --array`.",
      "type": "object",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "filtered_task_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "parent_job_id": {
          "type": "string"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "state_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ArrayTaskStatus"
          }
        }
      },
      "required": [
        "available",
        "parent_job_id",
        "tasks",
        "state_counts"
      ]
    },
    "ArrayTaskStatus": {
      "description": "One Slurm array task row.",
      "type": "object",
      "properties": {
        "elapsed": {
          "type": [
            "string",
            "null"
          ]
        },
        "elapsed_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "exit_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "job_id_raw": {
          "type": "string"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "$ref": "#/$defs/SchedulerSource"
        },
        "state": {
          "type": "string"
        },
        "task_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "job_id_raw",
        "state",
        "source"
      ]
    },
    "BatchLogStatus": {
      "description": "Presence and freshness information for the top-level batch log.",
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        },
        "updated_age_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "updated_at": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "path",
        "present"
      ]
    },
    "CollectorCoverage": {
      "description": "Evidence completeness for one node-scoped metrics collector.",
      "type": "object",
      "properties": {
        "degraded": {
          "type": "boolean",
          "default": false
        },
        "expected_nodes": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "observed_nodes": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "$ref": "#/$defs/CollectorCoverageScope",
          "default": "unknown"
        }
      }
    },
    "CollectorCoverageScope": {
      "description": "Node scope covered by one job-local metrics collector.",
      "type": "string",
      "enum": [
        "allocation",
        "batch_node",
        "unknown"
      ]
    },
    "CollectorCoverageSummary": {
      "description": "Lightweight collector coverage row exposed by status and analysis reports.",
      "type": "object",
      "properties": {
        "collector": {
          "type": "string"
        },
        "coverage": {
          "$ref": "#/$defs/CollectorCoverage"
        }
      },
      "required": [
        "collector",
        "coverage"
      ]
    },
    "GitProvenance": {
      "description": "Git state captured at submit time; only populated inside a working tree.",
      "type": "object",
      "properties": {
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "dirty": {
          "type": "boolean"
        },
        "sha": {
          "type": "string"
        }
      },
      "required": [
        "sha",
        "dirty"
      ]
    },
    "JobNote": {
      "description": "One append-only observation attached to a tracked job record via\n`experiment note`.",
      "type": "object",
      "properties": {
        "created_at": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "created_at"
      ]
    },
    "JobProvenance": {
      "description": "Provenance pinned into a tracked submission record. Descriptive only.",
      "type": "object",
      "properties": {
        "git": {
          "anyOf": [
            {
              "$ref": "#/$defs/GitProvenance"
            },
            {
              "type": "null"
            }
          ]
        },
        "image_refs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "source_content_hash": {
          "description": "Content hash of the working-tree source snapshot captured at submit (the\nCAS key from [`crate::cache::source::stage_source`]). Populated only on\nthe approval-gated submit path; `None` when source was not snapshotted.",
          "type": [
            "string",
            "null"
          ]
        },
        "tool_version": {
          "type": "string"
        }
      },
      "required": [
        "tool_version"
      ]
    },
    "PsServiceRow": {
      "description": "Presence and freshness information for one tracked service log.",
      "type": "object",
      "properties": {
        "assertions": {
          "anyOf": [
            {
              "$ref": "#/$defs/ServiceAssertionStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "completed_successfully": {
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "duration_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        },
        "failure_policy_mode": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "finished_at": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        },
        "healthy": {
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "last_exit_code": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32",
          "default": null
        },
        "launch_index": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "launcher_pid": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "log_path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "max_restarts": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "max_restarts_in_window": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "nodelist": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "nodes": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "ntasks": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "ntasks_per_node": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "path": {
          "type": "string"
        },
        "placement_mode": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "present": {
          "type": "boolean"
        },
        "readiness_configured": {
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "restart_count": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "restart_failures_in_window": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "service_name": {
          "type": "string"
        },
        "started_at": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        },
        "status": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "step_name": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "updated_age_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "updated_at": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "window_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        }
      },
      "required": [
        "service_name",
        "path",
        "present"
      ]
    },
    "QueueDiagnostics": {
      "description": "Optional queue-facing scheduler diagnostics returned only by `status`.",
      "type": "object",
      "properties": {
        "eligible_time": {
          "type": [
            "string",
            "null"
          ]
        },
        "pending_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "start_time": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "RequestedWalltime": {
      "description": "Parsed requested allocation walltime persisted with a tracked record.",
      "type": "object",
      "properties": {
        "original": {
          "type": "string"
        },
        "seconds": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "original",
        "seconds"
      ]
    },
    "SchedulerSource": {
      "description": "Source used to determine scheduler state.",
      "oneOf": [
        {
          "description": "State came from `squeue`.",
          "type": "string",
          "const": "squeue"
        },
        {
          "description": "State came from `sacct`.",
          "type": "string",
          "const": "sacct"
        },
        {
          "description": "No scheduler data was available; only local tracking data exists.",
          "type": "string",
          "const": "local_only"
        }
      ]
    },
    "SchedulerStatus": {
      "description": "Scheduler state as observed by the tracker.",
      "type": "object",
      "properties": {
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "failed": {
          "type": "boolean"
        },
        "source": {
          "$ref": "#/$defs/SchedulerSource"
        },
        "state": {
          "type": "string"
        },
        "terminal": {
          "type": "boolean"
        }
      },
      "required": [
        "state",
        "source",
        "terminal",
        "failed"
      ]
    },
    "ServiceAssertionStatus": {
      "description": "Post-run assertion result for one tracked service.",
      "type": "object",
      "properties": {
        "artifacts_contain": {
          "type": [
            "string",
            "null"
          ]
        },
        "configured": {
          "type": "boolean"
        },
        "duration_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "expected_exit_code": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "failures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_duration_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "configured",
        "failures"
      ]
    },
    "StatusVerificationCheck": {
      "description": "One verification check result.",
      "type": "object",
      "properties": {
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "suggestion": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "severity",
        "status",
        "summary"
      ]
    },
    "StatusVerificationReport": {
      "description": "Local consistency report for a tracked job status snapshot.",
      "type": "object",
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StatusVerificationCheck"
          }
        },
        "errors": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "ok": {
          "type": "boolean"
        },
        "schema_version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "schema_version",
        "ok",
        "errors",
        "warnings",
        "checks"
      ]
    },
    "SubmissionBackend": {
      "description": "Backend used to execute a tracked submission.",
      "oneOf": [
        {
          "description": "The job was submitted to Slurm.",
          "type": "string",
          "const": "slurm"
        },
        {
          "description": "The job was launched locally without Slurm.",
          "type": "string",
          "const": "local"
        }
      ]
    },
    "SubmissionKind": {
      "description": "High-level submission flow used to create a tracked job.",
      "oneOf": [
        {
          "description": "A normal compose application submission from `up`.",
          "type": "string",
          "const": "main"
        },
        {
          "description": "A one-off `run` submission scoped to one service.",
          "type": "string",
          "const": "run"
        },
        {
          "description": "A short right-sizing probe submitted by `germinate`.",
          "type": "string",
          "const": "canary"
        },
        {
          "description": "One trial submitted by `sweep submit`.",
          "type": "string",
          "const": "sweep_trial"
        },
        {
          "description": "A tracked interactive notebook server submitted by `notebook`.",
          "type": "string",
          "const": "notebook"
        }
      ]
    },
    "SubmissionRecord": {
      "description": "Metadata persisted for a submitted job tracked under `.hpc-compose/`.",
      "type": "object",
      "properties": {
        "artifact_export_dir": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "backend": {
          "$ref": "#/$defs/SubmissionBackend",
          "default": "slurm"
        },
        "batch_log": {
          "type": "string"
        },
        "batch_log_managed": {
          "description": "True when `batch_log` is the hpc-compose-owned default path and can be\nremoved by tracked-job cleanup. False for user-pinned `x-slurm.output`.",
          "type": "boolean"
        },
        "cache_dir": {
          "type": "string"
        },
        "cached_artifacts": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "command_override": {
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        },
        "compose_file": {
          "type": "string"
        },
        "config_snapshot_yaml": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "job_id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/SubmissionKind",
          "default": "main"
        },
        "notes": {
          "description": "Append-only timestamped observations attached after submission via\n`experiment note`. Additive; legacy records load with an empty list.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/JobNote"
          }
        },
        "provenance": {
          "description": "Best-effort provenance pinned at submit time (tool version, git state,\nper-service image refs). Optional and additive; legacy records load with\n`None`. Descriptive only — capturing it contacts no scheduler.",
          "anyOf": [
            {
              "$ref": "#/$defs/JobProvenance"
            },
            {
              "type": "null"
            }
          ]
        },
        "requested_walltime": {
          "anyOf": [
            {
              "$ref": "#/$defs/RequestedWalltime"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "resume_dir": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "runtime_root": {
          "description": "Resolved `x-slurm.runtime_root` override (the parent of `<job_id>/`).\n`None` when the default `<submit_dir>/.hpc-compose` layout is used;\nreaders fall back to that default via `runtime_job_root_for_record`.",
          "type": [
            "string",
            "null"
          ]
        },
        "schema_version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "script_path": {
          "type": "string"
        },
        "service_logs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "service_name": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "slurm_array": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "submit_dir": {
          "type": "string"
        },
        "submitted_at": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "sweep": {
          "anyOf": [
            {
              "$ref": "#/$defs/SweepTrialMetadata"
            },
            {
              "type": "null"
            }
          ]
        },
        "tags": {
          "description": "Short user-assigned labels attached after submission via\n`experiment tag` (e.g. \"baseline\", \"lr-bug\"). Set semantics: kept\nsorted and deduplicated. Additive; legacy records load with an empty\nlist.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema_version",
        "job_id",
        "submitted_at",
        "compose_file",
        "submit_dir",
        "script_path",
        "cache_dir",
        "batch_log",
        "service_logs"
      ]
    },
    "SweepTrialMetadata": {
      "description": "Sweep metadata attached to a trial submission record.",
      "type": "object",
      "properties": {
        "sweep_id": {
          "type": "string"
        },
        "trial_id": {
          "type": "string"
        },
        "trial_index": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "variables": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "sweep_id",
        "trial_id",
        "trial_index",
        "variables"
      ]
    },
    "WatchdogAction": {
      "description": "Advisory idle-resource watchdog action.",
      "oneOf": [
        {
          "description": "Surface an advisory in status/watch/stats output.",
          "type": "string",
          "const": "warn"
        },
        {
          "description": "Reserved for a future runtime-enforced self-cancel policy.",
          "type": "string",
          "const": "cancel"
        }
      ]
    },
    "WatchdogClassification": {
      "description": "Resource state inferred from sustained sampler history.",
      "type": "string",
      "enum": [
        "active",
        "idle",
        "resident_idle",
        "wrapper_stuck",
        "io_wait_like",
        "insufficient_window",
        "no_samples",
        "missing_compute_signal"
      ]
