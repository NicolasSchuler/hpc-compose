{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StatsOutput",
  "description": "`stats` metrics and scheduler view (`--format json`).",
  "type": "object",
  "properties": {
    "accounting": {
      "anyOf": [
        {
          "$ref": "#/$defs/AccountingSnapshot"
        },
        {
          "type": "null"
        }
      ]
    },
    "attempt": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0
    },
    "available": {
      "type": "boolean"
    },
    "first_failure": {
      "anyOf": [
        {
          "$ref": "#/$defs/FirstFailure"
        },
        {
          "type": "null"
        }
      ]
    },
    "is_resume": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "job_id": {
      "type": "string"
    },
    "metrics_dir": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "record": {
      "anyOf": [
        {
          "$ref": "#/$defs/SubmissionRecord"
        },
        {
          "type": "null"
        }
      ]
    },
    "resume_dir": {
      "type": [
        "string",
        "null"
      ]
    },
    "sampler": {
      "anyOf": [
        {
          "$ref": "#/$defs/SamplerSnapshot"
        },
        {
          "type": "null"
        }
      ]
    },
    "scheduler": {
      "$ref": "#/$defs/SchedulerStatus"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "source": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/StepStats"
      }
    },
    "watchdog": {
      "anyOf": [
        {
          "$ref": "#/$defs/WatchdogSnapshot"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "schema_version",
    "job_id",
    "scheduler",
    "available",
    "source",
    "notes",
    "steps"
  ],
  "$defs": {
    "AccountingRow": {
      "description": "One parsed `sacct` row.",
      "type": "object",
      "properties": {
        "account": {
          "type": [
            "string",
            "null"
          ]
        },
        "alloc_cpus": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "alloc_tres": {
          "type": "string"
        },
        "alloc_tres_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "cpu_time_raw_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "elapsed_raw_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "end": {
          "type": [
            "string",
            "null"
          ]
        },
        "exit_code": {
          "type": "string"
        },
        "job_id_raw": {
          "type": "string"
        },
        "job_name": {
          "type": "string"
        },
        "max_rss_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "nnodes": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "partition": {
          "type": [
            "string",
            "null"
          ]
        },
        "qos": {
          "type": [
            "string",
            "null"
          ]
        },
        "req_tres": {
          "type": "string"
        },
        "req_tres_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "start": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": "string"
        },
        "total_cpu_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "tres_usage_in_tot": {
          "type": "string"
        },
        "tres_usage_in_tot_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "job_id_raw",
        "job_name",
        "state",
        "exit_code",
        "alloc_tres",
        "req_tres",
        "alloc_tres_map",
        "req_tres_map",
        "tres_usage_in_tot",
        "tres_usage_in_tot_map"
      ]
    },
    "AccountingSnapshot": {
      "description": "Slurm accounting data returned by `stats --accounting`.",
      "type": "object",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AccountingRow"
          }
        },
        "source": {
          "type": "string"
        },
        "summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/AccountingSummary"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "available",
        "source",
        "rows"
      ]
    },
    "AccountingSummary": {
      "description": "Grant-report friendly accounting rollup.",
      "type": "object",
      "properties": {
        "allocated_cpu_hours": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "allocated_gpu_hours": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "allocated_memory_byte_seconds": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "max_rss_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "memory_basis": {
          "type": "string"
        },
        "total_cpu_hours": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      },
      "required": [
        "memory_basis"
      ]
    },
    "CollectorCoverage": {
      "description": "Evidence completeness for one node-scoped metrics collector.",
      "type": "object",
      "properties": {
        "degraded": {
          "type": "boolean",
          "default": false
        },
        "expected_nodes": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "observed_nodes": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "$ref": "#/$defs/CollectorCoverageScope",
          "default": "unknown"
        }
      }
    },
    "CollectorCoverageScope": {
      "description": "Node scope covered by one job-local metrics collector.",
      "type": "string",
      "enum": [
        "allocation",
        "batch_node",
        "unknown"
      ]
    },
    "CollectorCoverageSummary": {
      "description": "Lightweight collector coverage row exposed by status and analysis reports.",
      "type": "object",
      "properties": {
        "collector": {
          "type": "string"
        },
        "coverage": {
          "$ref": "#/$defs/CollectorCoverage"
        }
      },
      "required": [
        "collector",
        "coverage"
      ]
    },
    "CollectorStatus": {
      "description": "Availability metadata for one configured metrics collector.",
      "type": "object",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "coverage": {
          "anyOf": [
            {
              "$ref": "#/$defs/CollectorCoverage"
            },
            {
              "type": "null"
            }
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "last_sampled_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "enabled",
        "available"
      ]
    },
    "CpuNodeSample": {
      "description": "One node's latest sampled CPU utilization row.",
      "type": "object",
      "properties": {
        "core_count": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "cpu_util_pct": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "loadavg_1m": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "node": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "CpuSnapshot": {
      "description": "Sampled host CPU telemetry collected from `/proc/stat` by the job-local\nsampler.",
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CpuNodeSample"
          }
        },
        "sampled_at": {
          "type": "string"
        },
        "summary": {
          "$ref": "#/$defs/CpuSummary"
        }
      },
      "required": [
        "sampled_at",
        "nodes",
        "summary"
      ]
    },
    "CpuSummary": {
      "description": "Cross-node rollup of the latest CPU utilization sample.",
      "type": "object",
      "properties": {
        "max_util_pct": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "mean_util_pct": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "node_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "total_core_count": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "node_count"
      ]
    },
    "FirstFailure": {
      "description": "Best-effort first service failure observed by the runtime supervisor.",
      "type": "object",
      "properties": {
        "at_unix": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "exit_code": {
          "type": "integer",
          "format": "int32"
        },
        "node": {
          "type": [
            "string",
            "null"
          ]
        },
        "rank": {
          "type": [
            "string",
            "null"
          ]
        },
        "service": {
          "type": "string"
        }
      },
      "required": [
        "service",
        "exit_code"
      ]
    },
    "GitProvenance": {
      "description": "Git state captured at submit time; only populated inside a working tree.",
      "type": "object",
      "properties": {
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "dirty": {
          "type": "boolean"
        },
        "sha": {
          "type": "string"
        }
      },
      "required": [
        "sha",
        "dirty"
      ]
    },
    "GpuDeviceSample": {
      "description": "One sampled GPU device record.",
      "type": "object",
      "properties": {
        "collector": {
          "type": [
            "string",
            "null"
          ]
        },
        "index": {
          "type": [
            "string",
            "null"
          ]
        },
        "local_rank": {
          "type": [
            "string",
            "null"
          ]
        },
        "memory_total_mib": {
          "type": [
            "string",
            "null"
          ]
        },
        "memory_used_mib": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "node": {
          "type": [
            "string",
            "null"
          ]
        },
        "power_draw_w": {
          "type": [
            "string",
            "null"
          ]
        },
        "power_limit_w": {
          "type": [
            "string",
            "null"
          ]
        },
        "rank": {
          "type": [
            "string",
            "null"
          ]
        },
        "service": {
          "type": [
            "string",
            "null"
          ]
        },
        "temperature_c": {
          "type": [
            "string",
            "null"
          ]
        },
        "utilization_gpu": {
          "type": [
            "string",
            "null"
          ]
        },
        "utilization_memory": {
          "type": [
            "string",
            "null"
          ]
        },
        "uuid": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "GpuNodeSummary": {
      "description": "Per-node GPU summary derived from the latest sampler rows.",
      "type": "object",
      "properties": {
        "avg_utilization_gpu": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "gpu_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "memory_total_mib": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "memory_used_mib": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "node": {
          "type": [
            "string",
            "null"
          ]
        },
        "power_draw_w": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "power_limit_w": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      },
      "required": [
        "gpu_count"
      ]
    },
    "GpuProcessSample": {
      "description": "One sampled GPU process record.",
      "type": "object",
      "properties": {
        "collector": {
          "type": [
            "string",
            "null"
          ]
        },
        "gpu_uuid": {
          "type": [
            "string",
            "null"
          ]
        },
        "local_rank": {
          "type": [
            "string",
            "null"
          ]
        },
        "node": {
          "type": [
            "string",
            "null"
          ]
        },
        "pid": {
          "type": [
            "string",
            "null"
          ]
        },
        "process_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "rank": {
          "type": [
            "string",
            "null"
          ]
        },
        "service": {
          "type": [
            "string",
            "null"
          ]
        },
        "used_memory_mib": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "GpuSnapshot": {
      "description": "GPU telemetry snapshot collected by the job-local sampler.",
      "type": "object",
      "properties": {
        "gpus": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GpuDeviceSample"
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GpuNodeSummary"
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GpuProcessSample"
          }
        },
        "sampled_at": {
          "type": "string"
        }
      },
      "required": [
        "sampled_at",
        "nodes",
        "gpus",
        "processes"
      ]
    },
    "JobNote": {
      "description": "One append-only observation attached to a tracked job record via\n`experiment note`.",
      "type": "object",
      "properties": {
        "created_at": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "created_at"
      ]
    },
    "JobProvenance": {
      "description": "Provenance pinned into a tracked submission record. Descriptive only.",
      "type": "object",
      "properties": {
        "git": {
          "anyOf": [
            {
              "$ref": "#/$defs/GitProvenance"
            },
            {
              "type": "null"
            }
          ]
        },
        "image_refs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "source_content_hash": {
          "description": "Content hash of the working-tree source snapshot captured at submit (the\nCAS key from [`crate::cache::source::stage_source`]). Populated only on\nthe approval-gated submit path; `None` when source was not snapshotted.",
          "type": [
            "string",
            "null"
          ]
        },
        "tool_version": {
          "type": "string"
        }
      },
      "required": [
        "tool_version"
      ]
    },
    "RequestedWalltime": {
      "description": "Parsed requested allocation walltime persisted with a tracked record.",
      "type": "object",
      "properties": {
        "original": {
          "type": "string"
        },
        "seconds": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "original",
        "seconds"
      ]
    },
    "SamplerSnapshot": {
      "description": "Snapshot of the job-local metrics sampler outputs.",
      "type": "object",
      "properties": {
        "collectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CollectorStatus"
          }
        },
        "cpu": {
          "anyOf": [
            {
              "$ref": "#/$defs/CpuSnapshot"
            },
            {
              "type": "null"
            }
          ]
        },
        "gpu": {
          "anyOf": [
            {
              "$ref": "#/$defs/GpuSnapshot"
            },
            {
              "type": "null"
            }
          ]
        },
        "interval_seconds": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "slurm": {
          "anyOf": [
            {
              "$ref": "#/$defs/SlurmSamplerSnapshot"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "interval_seconds",
        "collectors"
      ]
    },
    "SchedulerSource": {
      "description": "Source used to determine scheduler state.",
      "oneOf": [
        {
          "description": "State came from `squeue`.",
          "type": "string",
          "const": "squeue"
        },
        {
          "description": "State came from `sacct`.",
          "type": "string",
          "const": "sacct"
        },
        {
          "description": "No scheduler data was available; only local tracking data exists.",
          "type": "string",
          "const": "local_only"
        }
      ]
    },
    "SchedulerStatus": {
      "description": "Scheduler state as observed by the tracker.",
      "type": "object",
      "properties": {
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "failed": {
          "type": "boolean"
        },
        "source": {
          "$ref": "#/$defs/SchedulerSource"
        },
        "state": {
          "type": "string"
        },
        "terminal": {
          "type": "boolean"
        }
      },
      "required": [
        "state",
        "source",
        "terminal",
        "failed"
      ]
    },
    "SlurmSamplerSnapshot": {
      "description": "Slurm metrics sampler output for all observed steps.",
      "type": "object",
      "properties": {
        "sampled_at": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StepStats"
          }
        }
      },
      "required": [
        "sampled_at",
        "steps"
      ]
    },
    "StepStats": {
      "description": "One Slurm step metrics row as presented by `hpc-compose stats`.",
      "type": "object",
      "properties": {
        "alloc_tres": {
          "type": "string"
        },
        "alloc_tres_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "ave_cpu": {
          "type": "string"
        },
        "ave_rss": {
          "type": "string"
        },
        "gpu_count": {
          "type": [
            "string",
            "null"
          ]
        },
        "gpu_mem": {
          "type": [
            "string",
            "null"
          ]
        },
        "gpu_util": {
          "type": [
            "string",
            "null"
          ]
        },
        "max_rss": {
          "type": "string"
        },
        "ntasks": {
          "type": "string"
        },
        "step_id": {
          "type": "string"
        },
        "tres_usage_in_ave": {
          "type": "string"
        },
        "usage_tres_in_ave_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "step_id",
        "ntasks",
        "ave_cpu",
        "ave_rss",
        "max_rss",
        "alloc_tres",
        "tres_usage_in_ave",
        "alloc_tres_map",
        "usage_tres_in_ave_map"
      ]
    },
    "SubmissionBackend": {
      "description": "Backend used to execute a tracked submission.",
      "oneOf": [
        {
          "description": "The job was submitted to Slurm.",
          "type": "string",
          "const": "slurm"
        },
        {
          "description": "The job was launched locally without Slurm.",
          "type": "string",
          "const": "local"
        }
      ]
    },
    "SubmissionKind": {
      "description": "High-level submission flow used to create a tracked job.",
      "oneOf": [
        {
          "description": "A normal compose application submission from `up`.",
          "type": "string",
          "const": "main"
        },
        {
          "description": "A one-off `run` submission scoped to one service.",
          "type": "string",
          "const": "run"
        },
        {
          "description": "A short right-sizing probe submitted by `germinate`.",
          "type": "string",
          "const": "canary"
        },
        {
          "description": "One trial submitted by `sweep submit`.",
          "type": "string",
          "const": "sweep_trial"
        },
        {
          "description": "A tracked interactive notebook server submitted by `notebook`.",
          "type": "string",
          "const": "notebook"
        }
      ]
    },
    "SubmissionRecord": {
      "description": "Metadata persisted for a submitted job tracked under `.hpc-compose/`.",
      "type": "object",
      "properties": {
        "artifact_export_dir": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "backend": {
          "$ref": "#/$defs/SubmissionBackend",
          "default": "slurm"
        },
        "batch_log": {
          "type": "string"
        },
        "batch_log_managed": {
          "description": "True when `batch_log` is the hpc-compose-owned default path and can be\nremoved by tracked-job cleanup. False for user-pinned `x-slurm.output`.",
          "type": "boolean"
        },
        "cache_dir": {
          "type": "string"
        },
        "cached_artifacts": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "command_override": {
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        },
        "compose_file": {
          "type": "string"
        },
        "config_snapshot_yaml": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "job_id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/SubmissionKind",
          "default": "main"
        },
        "notes": {
          "description": "Append-only timestamped observations attached after submission via\n`experiment note`. Additive; legacy records load with an empty list.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/JobNote"
          }
        },
        "provenance": {
          "description": "Best-effort provenance pinned at submit time (tool version, git state,\nper-service image refs). Optional and additive; legacy records load with\n`None`. Descriptive only — capturing it contacts no scheduler.",
          "anyOf": [
            {
              "$ref": "#/$defs/JobProvenance"
            },
            {
              "type": "null"
            }
          ]
        },
        "requested_walltime": {
          "anyOf": [
            {
              "$ref": "#/$defs/RequestedWalltime"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "resume_dir": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "runtime_root": {
          "description": "Resolved `x-slurm.runtime_root` override (the parent of `<job_id>/`).\n`None` when the default `<submit_dir>/.hpc-compose` layout is used;\nreaders fall back to that default via `runtime_job_root_for_record`.",
          "type": [
            "string",
            "null"
          ]
        },
        "schema_version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "script_path": {
          "type": "string"
        },
        "service_logs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "service_name": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "slurm_array": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "submit_dir": {
          "type": "string"
        },
        "submitted_at": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "sweep": {
          "anyOf": [
            {
              "$ref": "#/$defs/SweepTrialMetadata"
            },
            {
              "type": "null"
            }
          ]
        },
        "tags": {
          "description": "Short user-assigned labels attached after submission via\n`experiment tag` (e.g. \"baseline\", \"lr-bug\"). Set semantics: kept\nsorted and deduplicated. Additive; legacy records load with an empty\nlist.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema_version",
        "job_id",
        "submitted_at",
        "compose_file",
        "submit_dir",
        "script_path",
        "cache_dir",
        "batch_log",
        "service_logs"
      ]
    },
    "SweepTrialMetadata": {
      "description": "Sweep metadata attached to a trial submission record.",
      "type": "object",
      "properties": {
        "sweep_id": {
          "type": "string"
        },
        "trial_id": {
          "type": "string"
        },
        "trial_index": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "variables": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "sweep_id",
        "trial_id",
        "trial_index",
        "variables"
      ]
    },
    "WatchdogAction": {
      "description": "Advisory idle-resource watchdog action.",
      "oneOf": [
        {
          "description": "Surface an advisory in status/watch/stats output.",
          "type": "string",
          "const": "warn"
        },
        {
          "description": "Reserved for a future runtime-enforced self-cancel policy.",
          "type": "string",
          "const": "cancel"
        }
      ]
    },
    "WatchdogClassification": {
      "description": "Resource state inferred from sustained sampler history.",
      "type": "string",
      "enum": [
        "active",
        "idle",
        "resident_idle",
        "wrapper_stuck",
        "io_wait_like",
        "insufficient_window",
        "no_samples",
        "missing_compute_signal"
      ]
    },
    "WatchdogObservation": {
      "description": "One watchdog observation over a sustained history window.",
      "type": "object",
      "properties": {
        "classification": {
          "$ref": "#/$defs/WatchdogClassification"
        },
        "max_compute_pct": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "mean_compute_pct": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "memory_resident_pct": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "memory_signal": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "observed_seconds": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "resource": {
          "$ref": "#/$defs/WatchdogResource"
        },
        "sample_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "status": {
          "$ref": "#/$defs/WatchdogStatus"
        },
        "window_seconds": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "resource",
        "status",
        "classification",
        "window_seconds",
        "observed_seconds",
        "sample_count",
        "message"
      ]
    },
    "WatchdogResource": {
      "description": "Resource classified by the idle-resource watchdog.",
      "type": "string",
      "enum": [
        "gpu",
        "cpu"
      ]
    },
    "WatchdogSnapshot": {
      "description": "Advisory watchdog snapshot included in status/stats outputs.",
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/WatchdogAction"
        },
        "confidence_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean"
        },
        "grace_period_seconds": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "message": {
          "type": "string"
        },
        "observations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WatchdogObservation"
          }
        },
        "status": {
          "$ref": "#/$defs/WatchdogStatus"
        },
        "telemetry_coverage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CollectorCoverageSummary"
          }
        }
      },
      "required": [
        "enabled",
        "action",
        "status",
        "message",
        "grace_period_seconds",
        "observations"
      ]
    },
    "WatchdogStatus": {
      "description": "Status of the advisory idle-resource watchdog.",
      "type": "string",
      "enum": [
        "ok",
        "warning",
        "pending",
        "unavailable"
      ]
    }
  }
}
