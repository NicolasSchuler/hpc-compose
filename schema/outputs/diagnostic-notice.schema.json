{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Notice",
  "description": "One user-facing notice emitted on stderr.",
  "type": "object",
  "properties": {
    "code": {
      "type": [
        "string",
        "null"
      ]
    },
    "level": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "remediation": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "schema_version",
    "level",
    "message"
  ]
}
