{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScoreOutput",
  "description": "`score` post-run efficiency report (`--format json`).",
  "type": "object",
  "properties": {
    "complete": {
      "type": "boolean"
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EfficiencyScoreComponent"
      }
    },
    "confidence": {
      "$ref": "#/$defs/EfficiencyScoreConfidence"
    },
    "confidence_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "energy_basis": {
      "type": "string"
    },
    "energy_kwh": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    },
    "grade": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scheduler_source": {
      "type": "string"
    },
    "scheduler_state": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "score": {
      "type": "integer",
      "format": "uint8",
      "maximum": 255,
      "minimum": 0
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "telemetry_coverage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CollectorCoverageSummary"
      }
    },
    "tips": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "schema_version",
    "job_id",
    "scheduler_state",
    "scheduler_source",
    "complete",
    "score",
    "grade",
    "components",
    "energy_basis",
    "confidence",
    "tips",
    "sources",
    "notes"
  ],
  "$defs": {
    "CollectorCoverage": {
      "description": "Evidence completeness for one node-scoped metrics collector.",
      "type": "object",
      "properties": {
        "degraded": {
          "type": "boolean",
          "default": false
        },
        "expected_nodes": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "observed_nodes": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "$ref": "#/$defs/CollectorCoverageScope",
          "default": "unknown"
        }
      }
    },
    "CollectorCoverageScope": {
      "description": "Node scope covered by one job-local metrics collector.",
      "type": "string",
      "enum": [
        "allocation",
        "batch_node",
        "unknown"
      ]
    },
    "CollectorCoverageSummary": {
      "description": "Lightweight collector coverage row exposed by status and analysis reports.",
      "type": "object",
      "properties": {
        "collector": {
          "type": "string"
        },
        "coverage": {
          "$ref": "#/$defs/CollectorCoverage"
        }
      },
      "required": [
        "collector",
        "coverage"
      ]
    },
    "EfficiencyScoreComponent": {
      "description": "One scored efficiency dimension.",
      "type": "object",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "confidence": {
          "$ref": "#/$defs/EfficiencyScoreConfidence"
        },
        "label": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "observed": {
          "type": [
            "string",
            "null"
          ]
        },
        "requested": {
          "type": [
            "string",
            "null"
          ]
        },
        "score": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 255,
          "minimum": 0
        },
        "source": {
          "type": "string"
        },
        "utilization": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "weight": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "name",
        "label",
        "available",
        "weight",
        "source",
        "confidence"
      ]
    },
    "EfficiencyScoreConfidence": {
      "description": "Confidence label for an efficiency score component.",
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
