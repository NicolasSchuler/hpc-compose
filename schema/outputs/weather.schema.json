{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WeatherOutput",
  "description": "`weather` cluster weather report (`--format json`).",
  "type": "object",
  "properties": {
    "cluster": {
      "type": [
        "string",
        "null"
      ]
    },
    "condition": {
      "$ref": "#/$defs/WeatherCondition"
    },
    "fairshare": {
      "anyOf": [
        {
          "$ref": "#/$defs/FairshareSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "maintenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MaintenanceNote"
      }
    },
    "nodes": {
      "anyOf": [
        {
          "$ref": "#/$defs/NodeSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "priority": {
      "anyOf": [
        {
          "$ref": "#/$defs/PrioritySummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "queue": {
      "anyOf": [
        {
          "$ref": "#/$defs/QueueSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "timestamp_unix": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "user": {
      "$ref": "#/$defs/UserJobSummary"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "schema_version",
    "timestamp_unix",
    "condition",
    "user",
    "maintenance",
    "warnings"
  ],
  "$defs": {
    "FairshareSummary": {
      "type": "object",
      "properties": {
        "account": {
          "type": [
            "string",
            "null"
          ]
        },
        "fairshare": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "user": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "GpuModelSummary": {
      "type": "object",
      "properties": {
        "free_devices": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "free_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "model": {
          "type": "string"
        },
        "total_devices": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "total_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "model",
        "total_nodes",
        "free_nodes",
        "total_devices",
        "free_devices"
      ]
    },
    "GpuSummary": {
      "type": "object",
      "properties": {
        "free_devices": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "free_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "models": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GpuModelSummary"
          }
        },
        "total_devices": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "total_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "total_nodes",
        "free_nodes",
        "total_devices",
        "free_devices",
        "models"
      ]
    },
    "MaintenanceNote": {
      "type": "object",
      "properties": {
        "nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "partition": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": "string"
        }
      },
      "required": [
        "state",
        "nodes"
      ]
    },
    "NodeClassSummary": {
      "type": "object",
      "properties": {
        "free_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "total_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "total_nodes",
        "free_nodes"
      ]
    },
    "NodeSummary": {
      "type": "object",
      "properties": {
        "cpu": {
          "$ref": "#/$defs/NodeClassSummary"
        },
        "free_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "gpu": {
          "$ref": "#/$defs/GpuSummary"
        },
        "total_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "unavailable_nodes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "total_nodes",
        "free_nodes",
        "unavailable_nodes",
        "cpu",
        "gpu"
      ]
    },
    "PrioritySummary": {
      "type": "object",
      "properties": {
        "average_priority": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "highest_priority": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "pending_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "top_job_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "pending_jobs"
      ]
    },
    "QueueSummary": {
      "type": "object",
      "properties": {
        "average_pending_wait_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "other_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "pending_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "running_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "start_sample_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "total_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "total_jobs",
        "running_jobs",
        "pending_jobs",
        "other_jobs",
        "start_sample_count"
      ]
    },
    "UserJobSummary": {
      "type": "object",
      "properties": {
        "other_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "pending_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "running_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "total_jobs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "user": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "total_jobs",
        "running_jobs",
        "pending_jobs",
        "other_jobs"
      ]
    },
    "WeatherCondition": {
      "type": "string",
      "enum": [
        "clear",
        "partly_busy",
        "busy",
        "stormy",
        "unknown"
      ]
    }
  }
}
