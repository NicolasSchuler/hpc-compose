{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RenderOutput",
  "type": "object",
  "properties": {
    "compose_file": {
      "type": "string"
    },
    "output_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "script": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "compose_file",
    "script"
  ]
}
