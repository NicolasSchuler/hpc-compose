{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LessonListOutput",
  "type": "object",
  "properties": {
    "lessons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LessonDescriptionOutput"
      }
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "schema_version",
    "lessons"
  ],
  "$defs": {
    "LessonDescriptionOutput": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "schema_version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "step_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StepDescriptionOutput"
          }
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "id",
        "title",
        "description",
        "step_count",
        "steps"
      ]
    },
    "StepDescriptionOutput": {
      "type": "object",
      "properties": {
        "concepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "source_templates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "summary",
        "concepts",
        "source_templates"
      ]
    }
  }
}
