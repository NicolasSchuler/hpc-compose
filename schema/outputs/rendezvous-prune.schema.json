{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RendezvousPruneOutput",
  "description": "`rendezvous prune` removal report (`--format json`).",
  "type": "object",
  "properties": {
    "cache_dir": {
      "type": "string"
    },
    "removed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "schema_version",
    "cache_dir",
    "removed"
  ]
}
