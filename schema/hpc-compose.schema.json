{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://nicolasschuler.github.io/hpc-compose/schema/hpc-compose.schema.json",
  "title": "hpc-compose specification",
  "description": "Compose-like specification accepted by hpc-compose. Rust validation remains the semantic source of truth.",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    {
      "required": ["services"],
      "not": { "required": ["steps"] }
    },
    {
      "required": ["steps"],
      "not": { "required": ["services"] }
    },
    {
      "required": ["extends"],
      "not": {
        "anyOf": [
          { "required": ["services"] },
          { "required": ["steps"] }
        ]
      }
    }
  ],
  "allOf": [
    {
      "not": {
        "required": ["modules", "x-env"],
        "properties": {
          "x-env": { "required": ["modules"] }
        }
      }
    }
  ],
  "properties": {
    "extends": {
      "$ref": "#/definitions/rootExtends"
    },
    "version": {
      "oneOf": [
        {
          "type": "string",
          "const": "1"
        },
        {
          "type": "integer",
          "const": 1
        }
      ],
      "default": "1",
      "description": "hpc-compose spec schema version. Omit for v1, or set to string \"1\" / integer 1."
    },
    "name": {
      "type": "string"
    },
    "runtime": {
      "$ref": "#/definitions/runtime"
    },
    "modules": {
      "$ref": "#/definitions/stringList",
      "description": "List-only shorthand for top-level x-env.modules.load."
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/service"
      }
    },
    "steps": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/service"
      },
      "description": "Alias for services."
    },
    "x-env": {
      "$ref": "#/definitions/softwareEnv"
    },
    "x-slurm": {
      "$ref": "#/definitions/slurm"
    },
    "sweep": {
      "$ref": "#/definitions/sweep"
    },
    "secrets": {
      "$ref": "#/definitions/secrets",
      "description": "Named secrets resolved from local files or environment variables. Each value feeds the interpolation map as a secret and is redacted in config/context output."
    }
  },
  "definitions": {
    "rootExtends": {
      "type": "string",
      "description": "Path to a base hpc-compose YAML file merged before interpolation and validation."
    },
    "serviceExtends": {
      "oneOf": [
        {
          "type": "string",
          "description": "Service name in the same file, or a .yaml/.yml file path whose same-named service is used as the base."
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["service"],
          "properties": {
            "file": {
              "type": "string",
              "description": "Optional base file path. Relative paths resolve from the file declaring extends."
            },
            "service": {
              "type": "string",
              "minLength": 1,
              "description": "Service name to extend from the current file or the referenced file."
            }
          }
        }
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "lineSafeString": {
      "type": "string",
      "not": {
        "anyOf": [
          { "pattern": "\\n|\\r" },
          { "pattern": "\\u0000" }
        ]
      }
    },
    "arraySpec": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        { "$ref": "#/definitions/lineSafeString" },
        { "not": { "pattern": "\\s" } },
        {
          "pattern": "^([0-9]+(-[0-9]+(:[1-9][0-9]*)?)?)(,([0-9]+(-[0-9]+(:[1-9][0-9]*)?)?))*(%[1-9][0-9]*)?$"
        }
      ],
      "description": "Slurm array index spec such as 0, 1-10, 1-10:2, 0,3,8-12, or 0-99%10."
    },
    "jobDependency": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*(_[0-9]+)?$"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(_[0-9]+)?$"
            },
            "condition": {
              "type": "string",
              "enum": ["afterany", "afterok", "afternotok"]
            }
          }
        }
      ]
    },
    "command": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "environment": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "duration": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string" }
      ]
    },
    "secrets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/secretSource" },
      "description": "Map of secret name to source. Each value is resolved into the interpolation map tagged as a secret."
    },
    "secretSource": {
      "type": "object",
      "additionalProperties": false,
      "description": "Exactly one of 'file' or 'env' must be set. 'file' reads the secret from a file relative to the compose directory; 'env' reads a named environment variable.",
      "properties": {
        "file": { "type": "string" },
        "env": { "type": "string" }
      }
    },
    "sweep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameters", "matrix"],
      "properties": {
        "parameters": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "allOf": [
              { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
              { "not": { "pattern": "^HPC_COMPOSE_SWEEP_" } }
            ]
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/sweepParameterValue" }
          },
          "description": "Interpolation variables expanded by hpc-compose sweep submit. Values must be scalar strings, numbers, or booleans."
        },
        "matrix": {
          "$ref": "#/definitions/sweepMatrix"
        },
        "objective": {
          "$ref": "#/definitions/sweepObjective",
          "description": "Optional objective parsed from terminal trials by `sweep observe` and used by `sweep stop --stop-when`."
        },
        "replicates": {
          "$ref": "#/definitions/positiveInteger",
          "default": 1,
          "description": "Number of seeded replicate trials per parameter config; status/observe roll up mean+/-std(n) per config."
        }
      },
      "description": "Embedded hyperparameter sweep metadata consumed by hpc-compose sweep submit/status/list. sweep.spec is intentionally unsupported in v1."
    },
    "sweepObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction"],
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["minimize", "maximize"],
          "description": "Whether lower or higher objective values are better."
        },
        "log_pattern": {
          "type": "string",
          "description": "Regex matched against the trial's primary service log; capture group `group` is parsed as a float."
        },
        "group": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Capture group index for log_pattern (1-based)."
        },
        "json_path": {
          "type": "string",
          "description": "Artifact-collected JSON file whose json_field holds the objective."
        },
        "json_field": {
          "type": "string",
          "description": "Field to read from json_path. Required when json_path is set."
        }
      },
      "description": "Set exactly one of log_pattern or json_path."
    },
    "sweepParameterValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" }
      ]
    },
    "sweepMatrix": {
      "oneOf": [
        {
          "type": "string",
          "const": "full",
          "description": "Generate the full Cartesian product over sorted parameter names."
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["random"],
          "properties": {
            "random": {
              "$ref": "#/definitions/positiveInteger",
              "description": "Number of combinations to sample without replacement."
            },
            "seed": {
              "type": "string",
              "description": "Optional stable seed for deterministic random ordering."
            }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["pyxis", "apptainer", "singularity", "host"],
          "default": "pyxis"
        },
        "gpu": {
          "type": "string",
          "enum": ["auto", "none", "nvidia"],
          "default": "auto"
        }
      }
    },
    "slurm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resources": { "$ref": "#/definitions/lineSafeString" },
        "job_name": { "$ref": "#/definitions/lineSafeString" },
        "partition": { "$ref": "#/definitions/lineSafeString" },
        "account": { "$ref": "#/definitions/lineSafeString" },
        "qos": { "$ref": "#/definitions/lineSafeString" },
        "time": { "$ref": "#/definitions/lineSafeString" },
        "nodes": { "$ref": "#/definitions/positiveInteger" },
        "ntasks": { "$ref": "#/definitions/positiveInteger" },
        "ntasks_per_node": { "$ref": "#/definitions/positiveInteger" },
        "cpus_per_task": { "$ref": "#/definitions/positiveInteger" },
        "mem": { "$ref": "#/definitions/lineSafeString" },
        "gres": { "$ref": "#/definitions/lineSafeString" },
        "gpus": { "$ref": "#/definitions/positiveInteger" },
        "gpus_per_node": { "$ref": "#/definitions/positiveInteger" },
        "gpus_per_task": { "$ref": "#/definitions/positiveInteger" },
        "cpus_per_gpu": { "$ref": "#/definitions/positiveInteger" },
        "mem_per_gpu": { "$ref": "#/definitions/lineSafeString" },
        "gpu_bind": { "$ref": "#/definitions/lineSafeString" },
        "cpu_bind": { "$ref": "#/definitions/lineSafeString" },
        "mem_bind": { "$ref": "#/definitions/lineSafeString" },
        "distribution": { "$ref": "#/definitions/lineSafeString" },
        "hint": { "$ref": "#/definitions/lineSafeString" },
        "constraint": { "$ref": "#/definitions/lineSafeString" },
        "output": { "$ref": "#/definitions/lineSafeString" },
        "error": { "$ref": "#/definitions/lineSafeString" },
        "chdir": { "$ref": "#/definitions/lineSafeString" },
        "array": { "$ref": "#/definitions/arraySpec" },
        "after_job": { "$ref": "#/definitions/jobDependency" },
        "dependency": {
          "type": "string",
          "enum": ["singleton"]
        },
        "cache_dir": { "type": "string" },
        "runtime_root": { "type": "string" },
        "cleanup": { "$ref": "#/definitions/cleanup" },
        "scratch": { "$ref": "#/definitions/scratch" },
        "stage_in": {
          "type": "array",
          "items": { "$ref": "#/definitions/stageIn" }
        },
        "stage_out": {
          "type": "array",
          "items": { "$ref": "#/definitions/stageOut" }
        },
        "burst_buffer": { "$ref": "#/definitions/burstBuffer" },
        "metrics": { "$ref": "#/definitions/metrics" },
        "artifacts": { "$ref": "#/definitions/artifacts" },
        "resume": { "$ref": "#/definitions/resume" },
        "notify": { "$ref": "#/definitions/notify" },
        "setup": { "$ref": "#/definitions/stringList" },
        "submit_args": {
          "type": "array",
          "items": { "$ref": "#/definitions/lineSafeString" },
          "description": "Raw SBATCH pass-through lines. hpc-compose validates line safety but not Slurm semantics."
        },
        "rendezvous": { "$ref": "#/definitions/rendezvousClient" },
        "parallelism": { "$ref": "#/definitions/parallelism" }
      }
    },
    "scratch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "mount"],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["shared", "node_local"],
          "default": "node_local"
        },
        "base": { "type": "string", "minLength": 1 },
        "mount": { "type": "string", "minLength": 1 },
        "cleanup": {
          "type": "string",
          "enum": ["always", "on_success", "never"],
          "default": "always"
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime_cache": {
          "type": "string",
          "enum": ["never", "on_success", "always"],
          "default": "never"
        }
      }
    },
    "stageMode": {
      "type": "string",
      "enum": ["rsync", "copy"],
      "default": "rsync"
    },
    "stageIn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "mode": { "$ref": "#/definitions/stageMode" }
      }
    },
    "stageOut": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "when": {
          "type": "string",
          "enum": ["always", "on_success", "on_failure"],
          "default": "always"
        },
        "mode": { "$ref": "#/definitions/stageMode" }
      }
    },
    "burstBuffer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "directives": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/lineSafeString",
            "pattern": "^#(BB|DW) "
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "interval_seconds": { "$ref": "#/definitions/positiveInteger" },
        "collectors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["gpu", "slurm"]
          }
        }
      }
    },
    "rendezvousName": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "rendezvousClient": {
      "oneOf": [
        { "$ref": "#/definitions/rendezvousName" },
        {
          "type": "array",
          "items": { "$ref": "#/definitions/rendezvousName" },
          "minItems": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["discover"],
          "properties": {
            "discover": {
              "oneOf": [
                { "$ref": "#/definitions/rendezvousName" },
                {
                  "type": "array",
                  "items": { "$ref": "#/definitions/rendezvousName" },
                  "minItems": 1
                }
              ]
            },
            "timeout_seconds": { "$ref": "#/definitions/positiveInteger" },
            "require": { "type": "boolean" }
          }
        }
      ]
    },
    "serviceRendezvous": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "register": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "port"],
          "properties": {
            "name": { "$ref": "#/definitions/rendezvousName" },
            "port": { "$ref": "#/definitions/positiveInteger" },
            "protocol": {
              "type": "string",
              "pattern": "^[A-Za-z0-9.+-]+$"
            },
            "path": {
              "type": "string",
              "pattern": "^$|^/"
            },
            "ttl_seconds": { "$ref": "#/definitions/positiveInteger" },
            "metadata": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    },
    "softwareEnv": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modules": {
          "oneOf": [
            { "$ref": "#/definitions/stringList" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "purge": { "type": "boolean" },
                "load": { "$ref": "#/definitions/stringList" }
              }
            }
          ]
        },
        "spack": {
          "type": "object",
          "additionalProperties": false,
          "required": ["view"],
          "properties": {
            "view": { "type": "string", "minLength": 1 }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "collect": {
          "type": "string",
          "enum": ["always", "on_success", "on_failure"]
        },
        "export_dir": { "type": "string" },
        "paths": { "$ref": "#/definitions/stringList" },
        "bundles": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/artifactBundle"
          }
        }
      }
    },
    "artifactBundle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": { "$ref": "#/definitions/stringList" }
      }
    },
    "resume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string" }
      }
    },
    "notify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "email": { "$ref": "#/definitions/emailNotify" }
      }
    },
    "emailNotify": {
      "type": "object",
      "additionalProperties": false,
      "required": ["to"],
      "properties": {
        "to": { "$ref": "#/definitions/lineSafeString" },
        "on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["start", "end", "fail", "all"]
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "not": {
            "required": ["script", "command"]
          }
        },
        {
          "not": {
            "required": ["script", "entrypoint"]
          }
        },
        {
          "not": {
            "required": ["modules", "x-env"],
            "properties": {
              "x-env": { "required": ["modules"] }
            }
          }
        }
      ],
      "properties": {
        "extends": { "$ref": "#/definitions/serviceExtends" },
        "image": { "type": "string" },
        "command": { "$ref": "#/definitions/command" },
        "entrypoint": { "$ref": "#/definitions/command" },
        "script": { "type": "string", "minLength": 1 },
        "environment": { "$ref": "#/definitions/environment" },
        "modules": {
          "$ref": "#/definitions/stringList",
          "description": "List-only shorthand for service x-env.modules.load."
        },
        "volumes": { "$ref": "#/definitions/stringList" },
        "working_dir": { "type": "string" },
        "depends_on": { "$ref": "#/definitions/dependsOn" },
        "readiness": { "$ref": "#/definitions/readiness" },
        "healthcheck": { "$ref": "#/definitions/healthcheck" },
        "assert": { "$ref": "#/definitions/serviceAssert" },
        "x-env": { "$ref": "#/definitions/softwareEnv" },
        "x-slurm": { "$ref": "#/definitions/serviceSlurm" },
        "x-runtime": { "$ref": "#/definitions/serviceRuntime" },
        "x-enroot": { "$ref": "#/definitions/serviceEnroot" }
      }
    },
    "dependsOn": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/dependencyCondition"
          }
        }
      ]
    },
    "dependencyCondition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "condition": {
          "type": "string",
          "enum": ["service_started", "service_healthy", "service_completed_successfully"]
        }
      }
    },
    "readiness": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "seconds"],
          "properties": {
            "type": { "const": "sleep" },
            "seconds": { "$ref": "#/definitions/nonNegativeInteger" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "port"],
          "properties": {
            "type": { "const": "tcp" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "host": { "type": "string" },
            "timeout_seconds": { "$ref": "#/definitions/nonNegativeInteger" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "pattern"],
          "properties": {
            "type": { "const": "log" },
            "pattern": { "type": "string" },
            "timeout_seconds": { "$ref": "#/definitions/nonNegativeInteger" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "url"],
          "properties": {
            "type": { "const": "http" },
            "url": { "type": "string" },
            "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
            "timeout_seconds": { "$ref": "#/definitions/nonNegativeInteger" }
          }
        }
      ]
    },
    "healthcheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": { "$ref": "#/definitions/command" },
        "timeout": { "$ref": "#/definitions/duration" },
        "disable": { "type": "boolean" },
        "interval": { "$ref": "#/definitions/duration" },
        "retries": { "$ref": "#/definitions/nonNegativeInteger" },
        "start_period": { "$ref": "#/definitions/duration" }
      }
    },
    "serviceAssert": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["exit_code"] },
        { "required": ["artifacts_contain"] },
        { "required": ["max_duration_seconds"] }
      ],
      "properties": {
        "exit_code": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "artifacts_contain": {
          "type": "string",
          "minLength": 1,
          "description": "Glob pattern that must match at least one path under /hpc-compose/job. Relative patterns are resolved under /hpc-compose/job."
        },
        "max_duration_seconds": { "$ref": "#/definitions/positiveInteger" }
      }
    },
    "serviceSlurm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodes": { "$ref": "#/definitions/positiveInteger" },
        "placement": { "$ref": "#/definitions/servicePlacement" },
        "ntasks": { "$ref": "#/definitions/positiveInteger" },
        "ntasks_per_node": { "$ref": "#/definitions/positiveInteger" },
        "cpus_per_task": { "$ref": "#/definitions/positiveInteger" },
        "gpus": { "$ref": "#/definitions/positiveInteger" },
        "gres": { "type": "string" },
        "gpus_per_node": { "$ref": "#/definitions/positiveInteger" },
        "gpus_per_task": { "$ref": "#/definitions/positiveInteger" },
        "cpus_per_gpu": { "$ref": "#/definitions/positiveInteger" },
        "mem_per_gpu": { "$ref": "#/definitions/lineSafeString" },
        "gpu_bind": { "$ref": "#/definitions/lineSafeString" },
        "cpu_bind": { "$ref": "#/definitions/lineSafeString" },
        "mem_bind": { "$ref": "#/definitions/lineSafeString" },
        "distribution": { "$ref": "#/definitions/lineSafeString" },
        "hint": { "$ref": "#/definitions/lineSafeString" },
        "time_limit": { "type": "string" },
        "extra_srun_args": { "$ref": "#/definitions/stringList" },
        "mpi": { "$ref": "#/definitions/mpi" },
        "failure_policy": { "$ref": "#/definitions/failurePolicy" },
        "prologue": { "$ref": "#/definitions/serviceHook" },
        "epilogue": { "$ref": "#/definitions/serviceHook" },
        "hooks": {
          "type": "array",
          "items": { "$ref": "#/definitions/serviceEventHook" }
        },
        "scratch": { "$ref": "#/definitions/serviceScratch" },
        "rendezvous": { "$ref": "#/definitions/serviceRendezvous" },
        "parallelism": { "$ref": "#/definitions/parallelism" }
      }
    },
    "serviceScratch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "serviceHook": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["script"],
          "properties": {
            "context": {
              "type": "string",
              "enum": ["host", "container"]
            },
            "script": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "serviceEventHook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["on", "script"],
      "properties": {
        "on": {
          "type": "string",
          "enum": ["restart", "window_exhausted"]
        },
        "context": {
          "type": "string",
          "enum": ["host"],
          "default": "host"
        },
        "script": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "servicePlacement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node_range": { "type": "string", "minLength": 1 },
        "node_count": { "$ref": "#/definitions/positiveInteger" },
        "node_percent": { "type": "integer", "minimum": 1, "maximum": 100 },
        "share_with": { "type": "string", "minLength": 1 },
        "start_index": { "$ref": "#/definitions/nonNegativeInteger" },
        "exclude": { "type": "string", "minLength": 1 },
        "allow_overlap": { "type": "boolean" }
      },
      "oneOf": [
        { "required": ["node_range"] },
        { "required": ["node_count"] },
        { "required": ["node_percent"] },
        { "required": ["share_with"] }
      ]
    },
    "mpi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.+-]*$"
        },
        "profile": {
          "type": "string",
          "enum": ["openmpi", "mpich", "intel_mpi"]
        },
        "implementation": {
          "type": "string",
          "enum": ["openmpi", "mpich", "intel_mpi", "mvapich2", "cray_mpi", "hpe_mpi", "unknown"]
        },
        "launcher": {
          "type": "string",
          "enum": ["srun"]
        },
        "expected_ranks": { "$ref": "#/definitions/positiveInteger" },
        "host_mpi": { "$ref": "#/definitions/hostMpi" }
      }
    },
    "parallelism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tensor", "pipeline"],
      "properties": {
        "tensor": { "$ref": "#/definitions/positiveInteger" },
        "pipeline": { "$ref": "#/definitions/positiveInteger" }
      },
      "description": "Descriptive tensor/pipeline parallelism geometry. Validation-only: no #SBATCH/srun flag is emitted; tensor * pipeline is cross-checked against nodes * gpus_per_node and surfaced as HPC_COMPOSE_TP_SIZE/HPC_COMPOSE_PP_SIZE."
    },
    "hostMpi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bind_paths": { "$ref": "#/definitions/stringList" },
        "env": { "$ref": "#/definitions/environment" }
      }
    },
    "failurePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["fail_job", "ignore", "restart_on_failure"]
        },
        "max_restarts": { "$ref": "#/definitions/nonNegativeInteger" },
        "backoff_seconds": { "$ref": "#/definitions/nonNegativeInteger" },
        "window_seconds": { "$ref": "#/definitions/nonNegativeInteger" },
        "max_restarts_in_window": { "$ref": "#/definitions/nonNegativeInteger" }
      }
    },
    "serviceEnroot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prepare": { "$ref": "#/definitions/prepare" }
      }
    },
    "serviceRuntime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prepare": { "$ref": "#/definitions/prepare" }
      }
    },
    "prepare": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": { "$ref": "#/definitions/stringList" },
        "mounts": { "$ref": "#/definitions/stringList" },
        "env": { "$ref": "#/definitions/environment" },
        "root": { "type": "boolean" }
      }
    }
  }
}
